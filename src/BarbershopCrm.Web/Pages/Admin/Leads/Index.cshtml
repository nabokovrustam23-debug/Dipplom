@page "/Admin/Leads"
@using BarbershopCrm.Domain.Enums
@model BarbershopCrm.Web.Pages.Admin.Leads.IndexModel
@{
    ViewData["Title"] = "Управление заявками — Тихого Часа";
    ViewData["ManagementTab"] = "leads";

    var countNew = Model.Items.Count(l => l.Status == LeadStatus.New);
    var countProg = Model.Items.Count(l => l.Status == LeadStatus.InProgress);
    var countDone = Model.Items.Count(l => l.Status == LeadStatus.Done);
    var countRej = Model.Items.Count(l => l.Status == LeadStatus.Rejected);
}

<partial name="_ManagementTabs" />

<section class="management-section animate-fade-in">
    
    <div class="leads-workspace-header">
        <div class="leads-workspace-header__content">
            <span class="leads-workspace-header__badge">Операционный отдел</span>
            <h2>Обработка заявок клиентов</h2>
            <p class="leads-workspace-header__subtitle">Конвертация входящего трафика в записи у кресла</p>
        </div>
        
        <div class="leads-mini-tracker">
            <div class="tracker-node node-new">
                <span class="tracker-node__value">@countNew</span>
                <span class="tracker-node__label">Новые</span>
            </div>
            <div class="tracker-node node-progress">
                <span class="tracker-node__value">@countProg</span>
                <span class="tracker-node__label">В работе</span>
            </div>
            <div class="tracker-node node-done">
                <span class="tracker-node__value">@countDone</span>
                <span class="tracker-node__label">Закрыто</span>
            </div>
            <div class="tracker-node node-rejected">
                <span class="tracker-node__value">@countRej</span>
                <span class="tracker-node__label">Отклонено</span>
            </div>
        </div>
    </div>

    <div class="modern-filter-hub">
        
        <div class="segmented-control" role="tablist" aria-label="Фильтр по статусам">
            <a class="segment-item @(string.IsNullOrEmpty(Model.Status) ? "segment-item--active" : "")"
               asp-page="/Admin/Leads/Index" asp-all-route-data="@FilterRoute(null)">Все потоки</a>
            <a class="segment-item segment-item--new @(Model.Status == LeadStatus.New ? "segment-item--active" : "")"
               asp-page="/Admin/Leads/Index" asp-all-route-data="@FilterRoute(LeadStatus.New)">Новые (@countNew)</a>
            <a class="segment-item segment-item--progress @(Model.Status == LeadStatus.InProgress ? "segment-item--active" : "")"
               asp-page="/Admin/Leads/Index" asp-all-route-data="@FilterRoute(LeadStatus.InProgress)">В работе (@countProg)</a>
            <a class="segment-item segment-item--done @(Model.Status == LeadStatus.Done ? "segment-item--active" : "")"
               asp-page="/Admin/Leads/Index" asp-all-route-data="@FilterRoute(LeadStatus.Done)">Готово</a>
            <a class="segment-item segment-item--rejected @(Model.Status == LeadStatus.Rejected ? "segment-item--active" : "")"
               asp-page="/Admin/Leads/Index" asp-all-route-data="@FilterRoute(LeadStatus.Rejected)">Отклоненные</a>
        </div>

        <form method="get" class="modern-filter-form">
            <div class="filter-form-grid">
                
                <div class="filter-field-box search-extend">
                    <div class="input-with-icon-layout">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="search-icon-inside">
                            <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <input type="text" id="Search" name="Search" value="@Model.Search"
                               class="input input--hub search-input-field" placeholder="Поиск по ФИО или номеру телефона клиента..." />
                    </div>
                </div>

                <div class="filter-field-box">
                    <select id="SortBy" name="SortBy" class="input input--hub" onchange="this.form.submit()">
                        <option value="created_desc" selected="@(Model.SortBy == "created_desc" || Model.SortBy == null)">Сначала новые поступления</option>
                        <option value="created_asc" selected="@(Model.SortBy == "created_asc")">Сначала старые заявки</option>
                        <option value="name_asc" selected="@(Model.SortBy == "name_asc")">Алфавитный порядок (А-Я)</option>
                    </select>
                </div>
            </div>

            <div class="filter-form-grid filter-form-grid--second-row">
                <div class="filter-field-box calendar-box">
                    <label for="DateFrom">Период с</label>
                    <input type="date" id="DateFrom" name="DateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" class="input input--hub" />
                </div>
                
                <div class="filter-field-box calendar-box">
                    <label for="DateTo">по</label>
                    <input type="date" id="DateTo" name="DateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" class="input input--hub" />
                </div>

                <div class="filter-field-box calendar-box">
                    <label for="Status">Статус-фильтр</label>
                    <select id="Status" name="Status" class="input input--hub" onchange="this.form.submit()">
                        <option value="">Все категории статусов</option>
                        @foreach (var s in Model.StatusOptions)
                        {
                            <option value="@s" selected="@(Model.Status == s)">@StatusLabels.LeadStatus(s)</option>
                        }
                    </select>
                </div>

                <div class="filter-hub-actions">
                    <button type="submit" class="btn btn--accent btn--sm">
                        <span>Применить</span>
                    </button>
                    <a class="btn btn--ghost btn--sm" asp-page="/Admin/Leads/Index" title="Сбросить все параметры">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                    </a>
                </div>
            </div>
            <input type="hidden" name="CurrentPage" value="@Model.CurrentPage" />
        </form>
    </div>

    <div class="search-results-counter">
        <p>Выведено <strong>@Model.Items.Count</strong> записей из общего пула <strong>@Model.TotalCount</strong> в системе
            @if (Model.TotalPages > 1)
            {
                <span class="page-indicator-text">· страница @Model.CurrentPage из @Model.TotalPages</span>
            }
        </p>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="premium-empty-state">
            <div class="empty-state-illustration">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                </svg>
            </div>
            <h4>Рабочий стол пуст</h4>
            <p>Заявок, удовлетворяющих заданным критериям фильтрации, на текущий момент не обнаружено.</p>
        </div>
    }
    else
    {
        <div class="leads-premium-list-layout">
            @foreach (var l in Model.Items)
            {
                var p1Done = l.Status != LeadStatus.New;
                var p1Active = l.Status == LeadStatus.New;
                var p2Active = l.Status == LeadStatus.InProgress;
                var p2Done = l.Status == LeadStatus.Done;
                var p2Skipped = l.Status == LeadStatus.Rejected;
                var p3Active = l.Status == LeadStatus.Done || l.Status == LeadStatus.Rejected;
                
                var outcomeLabel = l.Status == LeadStatus.Rejected
                    ? "Отклонена"
                    : (l.CreatedBookingId.HasValue ? "Запись оформлена" : "Закрыто без брони");

                <article class="lead-dashboard-card lead-card-status-@l.Status.ToLowerInvariant()">
                    
                    <div class="lead-dashboard-card__top">
                        <div class="compact-pipeline-tracker">
                            <span class="pipeline-node @(p1Active ? "is-active" : "") @(p1Done ? "is-done" : "")" title="Поступление">1</span>
                            <div class="pipeline-connector @(p1Done ? "is-done" : "")"></div>
                            
                            <span class="pipeline-node @(p2Active ? "is-active" : "") @(p2Done ? "is-done" : "") @(p2Skipped ? "is-skipped" : "")" title="Обработка">
                                @(p2Skipped ? "×" : "2")
                            </span>
                            <div class="pipeline-connector @(p2Done || p2Skipped ? "is-done" : "")"></div>
                            
                            <span class="pipeline-node @(p3Active ? "is-active is-outcome" : "")" title="Финал">3</span>
                            
                            @if (p3Active)
                            {
                                <span class="pipeline-outcome-badge @(l.Status == LeadStatus.Rejected ? "badge-out-rej" : "badge-out-ok")">
                                    @outcomeLabel
                                </span>
                            }
                        </div>
                        
                        <div class="lead-card-time">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                            <span>@l.CreatedAt.ToString("dd.MM.yyyy в HH:mm")</span>
                        </div>
                    </div>

                    <div class="lead-dashboard-card__main">
                        <div class="lead-customer-profile-box">
                            <div class="lead-customer-avatar">
                                @l.RawName.Substring(0, 1).ToUpper()
                            </div>
                            <div class="lead-customer-meta">
                                <h4 class="customer-title-name">@l.RawName</h4>
                                <a href="tel:@l.RawPhone.Replace(" ", "").Replace("(", "").Replace(")", "").Replace("-", "")" class="customer-phone-anchor">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                                    </svg>
                                    <span>@l.RawPhone</span>
                                </a>
                            </div>
                        </div>

                        <div class="lead-wishes-box">
                            @if (l.PreferredBranch != null)
                            {
                                <div class="wish-row">
                                    <span class="wish-row__label">Точка барбершопа:</span>
                                    <span class="wish-row__value">@l.PreferredBranch.Name</span>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(l.Comment))
                            {
                                <div class="wish-comment-bubble">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="quote-icon">
                                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                                    </svg>
                                    <p class="comment-text">@l.Comment</p>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="lead-dashboard-card__actions">
                        
                        @if (l.Status == LeadStatus.Done || l.Status == LeadStatus.Rejected)
                        {
                            <div class="lead-outcome-summary-view">
                                <span class="outcome-static-text">Карта закрыта со статусом: <strong>@StatusLabels.LeadStatus(l.Status)</strong></span>
                                @if (l.CreatedBookingId.HasValue && l.Status == LeadStatus.Done)
                                {
                                    <a class="btn btn--outline btn--sm btn--block-action" asp-page="/Admin/Bookings/Index" asp-route-bookingId="@l.CreatedBookingId.Value" asp-fragment="@($"booking-{l.CreatedBookingId.Value}")">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line>
                                        </svg>
                                        <span>Открыть запись №@l.CreatedBookingId.Value</span>
                                    </a>
                                }
                            </div>
                        }
                        
                        else if (l.Status == LeadStatus.New)
                        {
                            <div class="lead-action-workflow-buttons">
                                <form method="post" asp-page-handler="Take" asp-route-id="@l.LeadId" asp-route-status="@Model.Status" asp-route-search="@Model.Search" asp-route-sortby="@Model.SortBy" asp-route-datefrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateto="@Model.DateTo?.ToString("yyyy-MM-dd")" asp-route-currentpage="@Model.CurrentPage" data-busy class="action-form-stretch">
                                    <button class="btn btn--primary btn--sm btn--full-width" type="submit">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                                        </svg>
                                        <span>Взять заявку в работу</span>
                                    </button>
                                </form>
                                
                                <form method="post" asp-page-handler="Reject" asp-route-id="@l.LeadId" asp-route-status="@Model.Status" asp-route-search="@Model.Search" asp-route-sortby="@Model.SortBy" asp-route-datefrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateto="@Model.DateTo?.ToString("yyyy-MM-dd")" asp-route-currentpage="@Model.CurrentPage" data-busy onsubmit="return confirm('Отклонить входящую заявку клиента?')" class="action-form-shrink">
                                    <button class="btn btn--ghost-danger btn--sm" type="submit" title="Отклонить спам / неактуальную заявку">
                                        <span>Отклонить</span>
                                    </button>
                                </form>
                            </div>
                        }
                        
                        else if (l.Status == LeadStatus.InProgress)
                        {
                            <div class="lead-action-workflow-buttons lead-action-workflow-buttons--vertical">
                                <div class="primary-row-actions">
                                    <a class="btn btn--accent btn--sm btn--full-width btn--with-icon" asp-page="/Admin/Bookings/New" asp-route-leadId="@l.LeadId">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line>
                                        </svg>
                                        <span>Оформить запись клиента</span>
                                    </a>
                                </div>
                                
                                <div class="secondary-row-actions">
                                    <form method="post" asp-page-handler="Done" asp-route-id="@l.LeadId" asp-route-status="@Model.Status" asp-route-search="@Model.Search" asp-route-sortby="@Model.SortBy" asp-route-datefrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateto="@Model.DateTo?.ToString("yyyy-MM-dd")" asp-route-currentpage="@Model.CurrentPage" data-busy onsubmit="return confirm('Закрыть карту заявки без бронирования?')" class="sub-form-action">
                                        <button class="btn btn--outline-success btn--xs" type="submit">
                                            <span>Закрыть без записи</span>
                                        </button>
                                    </form>
                                    
                                    <form method="post" asp-page-handler="Reject" asp-route-id="@l.LeadId" asp-route-status="@Model.Status" asp-route-search="@Model.Search" asp-route-sortby="@Model.SortBy" asp-route-datefrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateto="@Model.DateTo?.ToString("yyyy-MM-dd")" asp-route-currentpage="@Model.CurrentPage" data-busy onsubmit="return confirm('Перевести заявку в статус Отклонена?')" class="sub-form-action">
                                        <button class="btn btn--outline-danger btn--xs" type="submit">
                                            <span>Отклонить заявку</span>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </article>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="premium-pagination-container" aria-label="Навигация по страницам заявок">
                @{
                    var routeData = new Dictionary<string, string?>
                    {
                        ["Status"] = Model.Status,
                        ["Search"] = Model.Search,
                        ["SortBy"] = Model.SortBy,
                        ["DateFrom"] = Model.DateFrom?.ToString("yyyy-MM-dd"),
                        ["DateTo"] = Model.DateTo?.ToString("yyyy-MM-dd"),
                        ["CurrentPage"] = Model.CurrentPage.ToString(),
                    };
                }
                
                @if (Model.CurrentPage > 1)
                {
                    <a class="btn btn--outline btn--sm pag-arrow-btn" asp-page="/Admin/Leads/Index" asp-all-route-data="@routeData" asp-route-currentpage="@(Model.CurrentPage - 1)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="15 18 9 12 15 6"></polyline>
                        </svg>
                        <span>Назад</span>
                    </a>
                }

                <div class="pag-numeric-nodes">
                    @{
                        var startPage = Math.Max(1, Model.CurrentPage - 2);
                        var endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
                    }
                    @if (startPage > 1)
                    {
                        <a class="btn btn--outline btn--sm pag-node" asp-page="/Admin/Leads/Index" asp-all-route-data="@routeData" asp-route-currentpage="1">1</a>
                        @if (startPage > 2)
                        {
                            <span class="pag-ellipsis-divider">...</span>
                        }
                    }
                    @for (var p = startPage; p <= endPage; p++)
                    {
                        <a class="btn @(p == Model.CurrentPage ? "btn--primary" : "btn--outline") btn--sm pag-node" asp-page="/Admin/Leads/Index" asp-all-route-data="@routeData" asp-route-currentpage="@p">@p</a>
                    }
                    @if (endPage < Model.TotalPages)
                    {
                        @if (endPage < Model.TotalPages - 1)
                        {
                            <span class="pag-ellipsis-divider">...</span>
                        }
                        <a class="btn btn--outline btn--sm pag-node" asp-page="/Admin/Leads/Index" asp-all-route-data="@routeData" asp-route-currentpage="@Model.TotalPages">@Model.TotalPages</a>
                    }
                </div>

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a class="btn btn--outline btn--sm pag-arrow-btn" asp-page="/Admin/Leads/Index" asp-all-route-data="@routeData" asp-route-currentpage="@(Model.CurrentPage + 1)">
                        <span>Вперёд</span>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="9 18 15 12 9 6"></polyline>
                        </svg>
                    </a>
                }
            </nav>
        }
    }
</section>

@section Scripts {
    <script src="~/js/form-busy.js" asp-append-version="true"></script>
}

@functions {
    Dictionary<string, string?> FilterRoute(string? statusOverride)
    {
        return new Dictionary<string, string?>
        {
            ["Status"] = statusOverride,
            ["Search"] = Model.Search,
            ["SortBy"] = Model.SortBy,
            ["DateFrom"] = Model.DateFrom?.ToString("yyyy-MM-dd"),
            ["DateTo"] = Model.DateTo?.ToString("yyyy-MM-dd"),
            ["CurrentPage"] = "1",
        };
    }
}

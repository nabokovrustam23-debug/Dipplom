@inject ICurrentUserAccessor CurrentUserAccessor
@{
    var theme = Context.Request.Cookies["theme"];
    if (theme != "light" && theme != "dark") theme = "dark";

    var nextTheme = theme == "dark" ? "light" : "dark";
    var nextThemeLabel = nextTheme == "dark" ? "Тёмная" : "Светлая";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;

    var current = CurrentUserAccessor.User;
}
<!DOCTYPE html>
<html lang="ru" data-theme="@theme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Тихий час") · CRM</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#main-content">Перейти к содержимому</a>
    <div class="app-shell">
        <header class="app-header">
            <div class="app-header__inner">
                <a class="brand" asp-page="/Index">
                    <img src="~/images/logo.png" alt="Тихий час" class="brand-logo" width="40" height="40" />
                    <div class="brand-text">
                        <span class="brand-mark">Тихий час</span>
                        <span class="brand-tag">барбершопы Краснодара</span>
                    </div>
                </a>
                <nav class="app-nav" aria-label="Главное меню">
                    <a asp-page="/Index" class="app-nav__link">Главная</a>
                    <a asp-page="/Services/Index" class="app-nav__link">Услуги</a>
                    <a asp-page="/Branches/Index" class="app-nav__link">Филиалы</a>
                    @if (current is not null && current.RoleCode == RoleCode.Client)
                    {
                        <a asp-page="/BookingFlow/New" class="app-nav__link app-nav__link--primary">Записаться</a>
                        <a asp-page="/Account/Bookings/Index" class="app-nav__link">Мои записи</a>
                    }
                    else
                    {
                        <a asp-page="/Lead/Index" class="app-nav__link app-nav__link--primary">Записаться</a>
                    }

                    @if (current is not null && current.RoleCode == RoleCode.Owner)
                    {
                        <a asp-page="/Owner/Branches/Index" class="app-nav__link nav-manage">Управление</a>
                    }
                    else if (current is not null && current.RoleCode == RoleCode.Admin)
                    {
                        <a asp-page="/Masters/Manage" class="app-nav__link nav-manage">Управление</a>
                    }
                    else if (current is not null && current.RoleCode == RoleCode.Master)
                    {
                        <a asp-page="/MasterArea/Bookings" class="app-nav__link nav-manage">Расписание</a>
                    }

                    <div class="app-nav__actions">
                        @if (current is null)
                        {
                            <a asp-page="/Account/Login" class="btn btn--ghost btn--sm">Войти</a>
                        }
                        else
                        {
                            <a asp-page="/Account/Notifications/Index" class="nav-icon-btn" title="Мои уведомления" aria-label="Уведомления">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                                    <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                                </svg>
                            </a>
                            <a asp-page="/Profile/Index" class="user-pill" title="@current.FullName · @current.RoleCode">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                                @(string.IsNullOrEmpty(current.ShortName) ? current.FullName : current.ShortName)
                            </a>
                            <form method="post" asp-page="/Account/Logout" class="logout-form">
                                <button type="submit" class="btn-link btn-link--subtle">Выход</button>
                            </form>
                        }

                        <a class="theme-toggle"
                           asp-page="/Theme/Set"
                           asp-route-value="@nextTheme"
                           asp-route-returnUrl="@returnUrl"
                           title="Переключить тему"
                           aria-label="Переключить тему">
                            @if (nextTheme == "dark")
                            {
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                                </svg>
                            }
                            else
                            {
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="5"></circle>
                                    <line x1="12" y1="1" x2="12" y2="3"></line>
                                    <line x1="12" y1="21" x2="12" y2="23"></line>
                                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                                    <line x1="1" y1="12" x2="3" y2="12"></line>
                                    <line x1="21" y1="12" x2="23" y2="12"></line>
                                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                                </svg>
                            }
                        </a>
                    </div>
                </nav>
            </div>
        </header>

        <main class="app-main" id="main-content" tabindex="-1">
            @{
                var successMsg = TempData["Success"] as string;
                var errorMsg = TempData["Error"] as string;
            }
            @if (!string.IsNullOrEmpty(successMsg))
            {
                <div class="toast toast--success" role="status" aria-live="polite">
                    <span class="toast__icon" aria-hidden="true">✓</span>
                    <span class="toast__text">@successMsg</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(errorMsg))
            {
                <div class="toast toast--error" role="alert" aria-live="assertive">
                    <span class="toast__icon" aria-hidden="true">!</span>
                    <span class="toast__text">@errorMsg</span>
                </div>
            }
            @RenderBody()
        </main>

        <partial name="_Footer" />
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

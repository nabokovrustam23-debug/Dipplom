@page
@model BarbershopCrm.Web.Pages.Owner.Branches.CreateModel
@{
    ViewData["Title"] = "Создание филиала";
    ViewData["ManagementTab"] = "branches";
}

<partial name="_ManagementTabs" />

<section class="branch-form-section">
    <div class="branch-form-header">
        <div>
            <h2>Создание нового филиала</h2>
            <p class="muted">Заполните информацию о новом филиале сети</p>
        </div>
        <a asp-page="Index" class="btn btn--ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Назад к списку
        </a>
    </div>

    <form method="post" enctype="multipart/form-data" class="branch-form" data-busy>
        <div asp-validation-summary="ModelOnly" class="alert alert--error"></div>

        <!-- Основная информация -->
        <div class="card">
            <div class="branch-form-section-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                </svg>
                <h3>Основная информация</h3>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Input.Name">
                        Название филиала
                        <span class="required-mark">*</span>
                    </label>
                    <input asp-for="Input.Name" 
                           class="input" 
                           placeholder="Например: Центральный, На Арбате" 
                           required 
                           autocomplete="off" />
                    <span asp-validation-for="Input.Name" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Address">
                        Адрес
                        <span class="required-mark">*</span>
                    </label>
                    <input asp-for="Input.Address" 
                           class="input" 
                           placeholder="Улица, дом, корпус" 
                           required 
                           autocomplete="street-address" />
                    <span asp-validation-for="Input.Address" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Phone">Телефон</label>
                    <div class="input-with-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                        </svg>
                        <input asp-for="Input.Phone" 
                               type="tel" 
                               class="input input--with-icon" 
                               placeholder="+7 (999) 123-45-67" 
                               autocomplete="tel" />
                    </div>
                    <span asp-validation-for="Input.Phone" class="field-error"></span>
                </div>
            </div>
        </div>

        <!-- Режим работы -->
        <div class="card">
            <div class="branch-form-section-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                <h3>Режим работы</h3>
            </div>

            <div class="form-grid">
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.OpeningTime">
                            Время открытия
                            <span class="required-mark">*</span>
                        </label>
                        <input asp-for="Input.OpeningTime" 
                               type="time" 
                               class="input" 
                               required />
                        <span asp-validation-for="Input.OpeningTime" class="field-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.ClosingTime">
                            Время закрытия
                            <span class="required-mark">*</span>
                        </label>
                        <input asp-for="Input.ClosingTime" 
                               type="time" 
                               class="input" 
                               required />
                        <span asp-validation-for="Input.ClosingTime" class="field-error"></span>
                    </div>
                </div>
                <small class="form-hint">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M12 16v-4"></path>
                        <path d="M12 8h.01"></path>
                    </svg>
                    Укажите время работы филиала. Это будет отображаться на сайте для клиентов.
                </small>
            </div>
        </div>

        <!-- Фото -->
        <div class="card">
            <div class="branch-form-section-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                    <polyline points="21 15 16 10 5 21"></polyline>
                </svg>
                <h3>Фотография филиала</h3>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Input.ImageFile">Выберите фото</label>
                    <input asp-for="Input.ImageFile" 
                           type="file" 
                           accept="image/*" 
                           class="input input--file" 
                           id="imageInput" />
                    <span asp-validation-for="Input.ImageFile" class="field-error"></span>
                    <small class="form-hint">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="M12 16v-4"></path>
                            <path d="M12 8h.01"></path>
                        </svg>
                        Рекомендуемый размер: 800×600 пикселей. Максимум 5 МБ. Форматы: JPG, PNG, WebP.
                    </small>
                </div>

                <div id="imagePreview" class="image-preview" style="display: none;">
                    <img id="previewImg" src="" alt="Предпросмотр" />
                    <button type="button" class="image-preview__remove" onclick="removeImage()">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Статус -->
        <div class="card">
            <div class="form-grid">
                <div class="form-group">
                    <label class="checkbox-inline">
                        <input asp-for="Input.IsActive" type="checkbox" />
                        <span class="checkbox-label-text">
                            <strong>Филиал активен</strong>
                            <small>Активные филиалы отображаются на сайте и доступны для записи</small>
                        </span>
                    </label>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                Создать филиал
            </button>
            <a asp-page="Index" class="btn btn--outline">Отмена</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('imageInput').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('previewImg').src = e.target.result;
                    document.getElementById('imagePreview').style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });

        function removeImage() {
            document.getElementById('imageInput').value = '';
            document.getElementById('imagePreview').style.display = 'none';
        }
    </script>
}

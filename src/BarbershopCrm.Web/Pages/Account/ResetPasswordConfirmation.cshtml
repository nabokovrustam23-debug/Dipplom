@page
@model BarbershopCrm.Web.Pages.Account.ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Пароль обновлён";
}

<section class="auth-shell">
    <div class="auth-card card">
        <h1>Пароль изменён</h1>
        <p class="muted">Все активные сессии завершены. Войдите с новым паролем.</p>
        <div class="auth-actions">
            <a asp-page="/Account/Login" class="btn btn--primary">Войти</a>
        </div>
    </div>
</section>

@page "/Admin/Bookings/New"
@model BarbershopCrm.Web.Pages.Admin.Bookings.NewModel
@{
    ViewData["Title"] = "Новая запись — Тихого Часа";
    ViewData["ManagementTab"] = "bookings";
    var minDate = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");
    var dateValue = !string.IsNullOrWhiteSpace(Model.Date) ? Model.Date! : minDate;
    var hasSlots = Model.BranchId.HasValue && Model.ServiceId.HasValue;
}

<partial name="_ManagementTabs" />

<section class="management-section booking-wizard-section animate-fade-in">
    
    <div class="analytics-header" style="margin-bottom: 2rem;">
        <div class="analytics-header__content">
            <span class="analytics-header__badge">Мастер бронирования</span>
            <h2>Создание записи администратором</h2>
            <p class="analytics-header__subtitle">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                <span>Пошаговое заполнение параметров: филиал → услуга → мастер → время → анкета гостя</span>
                <span class="page-indicator-text" style="margin-left: 0.5rem; font-weight: 600;">
                    @if (Model.LeadId.HasValue)
                    {
                        @:· На основании входящей заявки
                    }
                    else
                    {
                        @:· Прямая запись через ресепшн
                    }
                </span>
            </p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.LeadHint))
    {
        <div class="alert alert--info alert--modern" style="margin-bottom: 2rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
            <span>@Model.LeadHint</span>
        </div>
    }

    <div asp-validation-summary="All" class="alert alert--error alert--modern" style="margin-bottom: 2rem;"></div>

    <section class="analytics-filters-card booking-wizard-filters-box">
        <div class="analytics-filters-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line>
            </svg>
            <h3>Критерии сеанса</h3>
        </div>
        
        <form method="get" class="analytics-filters booking-wizard-get-form" data-busy>
            @if (Model.LeadId.HasValue)
            {
                <input type="hidden" name="LeadId" value="@Model.LeadId" />
            }
            
            <div class="filter-group">
                <label for="BranchId"><span>Шаг 1. Локация филиала</span></label>
                <select id="BranchId" name="BranchId" class="input input--filter" onchange="this.form.submit()">
                    <option value="">— выберите филиал сети —</option>
                    @foreach (var b in Model.Branches)
                    {
                        <option value="@b.BranchId" selected="@(Model.BranchId == b.BranchId)">@b.Name</option>
                    }
                </select>
            </div>
            
            @if (Model.BranchId.HasValue)
            {
                <div class="filter-group">
                    <label for="ServiceId"><span>Шаг 2. Выбор услуги</span></label>
                    <select id="ServiceId" name="ServiceId" class="input input--filter" onchange="this.form.submit()">
                        <option value="">— выберите услугу из прайса —</option>
                        @foreach (var s in Model.Services)
                        {
                            <option value="@s.ServiceId" selected="@(Model.ServiceId == s.ServiceId)">
                                @s.Name (@s.DurationMinutes мин · @s.Price.ToString("N0") ₽)
                            </option>
                        }
                    </select>
                </div>
            }
            
            @if (Model.BranchId.HasValue && Model.ServiceId.HasValue)
            {
                <div class="filter-group">
                    <label for="MasterId"><span>Шаг 3. Специалист кресла</span></label>
                    <select id="MasterId" name="MasterId" class="input input--filter" onchange="this.form.submit()">
                        <option value="">Любой свободный мастер</option>
                        @foreach (var m in Model.Masters)
                        {
                            <option value="@m.MasterId" selected="@(Model.MasterId == m.MasterId)">@m.FullName</option>
                        }
                    </select>
                </div>
                
                <div class="filter-group">
                    <label for="Date"><span>Дата визита</span></label>
                    <input type="date" id="Date" name="Date" class="input input--filter" value="@dateValue" min="@minDate" onchange="this.form.submit()" />
                </div>
            }
        </form>
    </section>

    @if (hasSlots)
    {
        <form method="post" data-busy class="booking-wizard-post-form">
            @if (Model.LeadId.HasValue)
            {
                <input type="hidden" name="LeadId" value="@Model.LeadId" />
            }
            <input type="hidden" name="Confirm.BranchId" value="@Model.BranchId" />
            <input type="hidden" name="Confirm.ServiceId" value="@Model.ServiceId" />
            <input type="hidden" name="Confirm.MasterId" id="ConfirmMasterId" value="0" />

            <div class="visual-chart-box visual-chart-box--full booking-slots-board-card" style="margin-top: 2rem;">
                <div class="visual-chart-box__header" style="padding: 0; margin-bottom: 2rem;">
                    <h4>Шаг 4. Свободные временные интервалы на @Model.DateValue.ToString("dd.MM.yyyy")</h4>
                </div>
                
                @if (!Model.Slots.Any())
                {
                    <div class="master-agenda-empty" style="padding: 3rem 0;">
                        <p>На указанную дату свободные слоты времени у мастеров отсутствуют. Измените число или выберите другого специалиста.</p>
                    </div>
                }
                else
                {
                    var slotsByMaster = Model.Slots
                        .GroupBy(s => new { s.MasterId, s.MasterName })
                        .OrderBy(g => g.Key.MasterName)
                        .ToList();
                        
                    <div class="booking-wizard-masters-slots-row" role="group" aria-label="Доступные окна по мастерам">
                        @foreach (var group in slotsByMaster)
                        {
                            <div class="master-slots-column-node">
                                <div class="master-slots-column-node__head">
                                    <div class="master-avatar-placeholder" style="width: 24px; height: 24px; font-size: 0.75rem;">@group.Key.MasterName.Substring(0, 1)</div>
                                    <span>@group.Key.MasterName</span>
                                </div>
                                <ul class="master-slots-column-node__list" role="listbox" aria-label="@group.Key.MasterName">
                                    @foreach (var slot in group.OrderBy(s => s.StartDateTime))
                                    {
                                        var iso = slot.StartDateTime.ToString("yyyy-MM-ddTHH:mm:ss");
                                        var label = slot.StartDateTime.ToString("HH:mm");
                                        <li>
                                            <label class="premium-slot-chip-pill">
                                                <input type="radio" name="Confirm.Slot" value="@iso" data-master="@slot.MasterId" required />
                                                <span class="slot-time-text">@label</span>
                                            </label>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                    <div style="margin-top: 1rem;"><span asp-validation-for="Confirm.Slot" class="field-error"></span></div>
                }
            </div>

            <fieldset class="visual-chart-box visual-chart-box--full booking-client-profile-fieldset" style="margin-top: 2rem; border: none;">
                <legend class="visual-chart-box__header" style="padding: 0; margin-bottom: 2rem; display: block; width: 100%;">
                    <h4 style="margin: 0;">Шаг 5. Карточка персональных данных гостя</h4>
                </legend>
                
                <div class="filter-form-grid" style="margin-bottom: 1.5rem;">
                    <div class="filter-field-box">
                        <label asp-for="Confirm.LastName" class="form-label-dark">Фамилия гостя</label>
                        <input asp-for="Confirm.LastName" class="input input--hub" autocomplete="family-name" required placeholder="Введите фамилию..." />
                        <span asp-validation-for="Confirm.LastName" class="field-error"></span>
                    </div>
                    <div class="filter-field-box">
                        <label asp-for="Confirm.FirstName" class="form-label-dark">Имя гостя</label>
                        <input asp-for="Confirm.FirstName" class="input input--hub" autocomplete="given-name" required placeholder="Введите имя..." />
                        <span asp-validation-for="Confirm.FirstName" class="field-error"></span>
                    </div>
                </div>
                
                <div class="filter-form-grid">
                    <div class="filter-field-box">
                        <label asp-for="Confirm.Phone" class="form-label-dark">Контактный мобильный телефон</label>
                        <input asp-for="Confirm.Phone" class="input input--hub tnum" autocomplete="tel" placeholder="+7 (900) 000-00-00" required />
                        <span asp-validation-for="Confirm.Phone" class="field-error"></span>
                    </div>
                    <div class="filter-field-box">
                        <label asp-for="Confirm.Email" class="form-label-dark">Электронная почта Email</label>
                        <input asp-for="Confirm.Email" class="input input--hub" type="email" autocomplete="email" placeholder="example@domain.com (необязательно)" />
                        <span asp-validation-for="Confirm.Email" class="field-error"></span>
                    </div>
                </div>
            </fieldset>

            <div class="form-actions-row" style="margin-top: 3rem; display: flex; gap: 1rem;">
                <button type="submit" class="btn btn--primary">
                    <span>Успешно создать запись</span>
                </button>
                <a asp-page="/Admin/Bookings/Index" class="btn btn--ghost">
                    <span>Отменить</span>
                </a>
            </div>
        </form>
    }
    else
    {
        <div class="master-agenda-empty" style="padding: 4rem 0; margin-top: 2rem;">
            <p>Пожалуйста, выберите подходящую локацию филиала и целевую услугу из прейскуранта выше, чтобы система сгенерировала сетку доступных окон времени.</p>
        </div>
    }
</section>

@section Scripts {
    <script src="~/js/form-busy.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('change', function(e) {
            if (e.target.matches('input[name="Confirm.Slot"]')) {
                var mid = e.target.getAttribute('data-master');
                var hidden = document.getElementById('ConfirmMasterId');
                if (hidden) hidden.value = mid || '0';
            }
        });
    </script>
}

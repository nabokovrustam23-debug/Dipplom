@page "/Branches/{id:int}"
@model BarbershopCrm.Web.Pages.Branches.DetailsModel
@{
    ViewData["Title"] = Model.Branch.Name;
}

<nav class="breadcrumbs faint" aria-label="Хлебные крошки">
    <a asp-page="/Branches/Index">Филиалы</a> ›
    <span>@Model.Branch.Name</span>
</nav>

<header class="page-header">
    <h1>@Model.Branch.Name</h1>
    <p class="muted">@Model.Branch.Address</p>
</header>

<div class="branch-details">
    @if (!string.IsNullOrEmpty(Model.Branch.ImageUrl))
    {
        <img class="image-thumb branch-details__image" src="@Model.Branch.ImageUrl" alt="Фотография филиала «@Model.Branch.Name»" />
    }
    else
    {
        <img class="image-thumb branch-details__image" src="~/images/branch-placeholder.svg" alt="" />
    }

    <dl class="info-list">
        <dt>Часы работы</dt>
        <dd class="tnum">@Model.Branch.OpeningTime.ToString("HH:mm") – @Model.Branch.ClosingTime.ToString("HH:mm")</dd>

        @if (!string.IsNullOrWhiteSpace(Model.Branch.Phone))
        {
            <dt>Телефон</dt>
            <dd class="tnum">
                <a href="tel:@Model.Branch.Phone.Replace(" ", "").Replace("(", "").Replace(")", "").Replace("-", "")">@Model.Branch.Phone</a>
            </dd>
        }
    </dl>
</div>

<section style="margin-top: var(--space-6);" aria-labelledby="masters-heading">
    <h2 id="masters-heading">Мастера филиала</h2>

    @if (Model.Masters.Count == 0)
    {
        <p class="muted">В этом филиале пока нет мастеров.</p>
    }
    else
    {
        <div class="grid-3" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); margin-top: var(--space-4);">
            @foreach (var master in Model.Masters)
            {
                var yearsOfExperience = (DateOnly.FromDateTime(DateTime.Today).Year - master.HireDate.Year);
                var experienceText = yearsOfExperience switch
                {
                    0 => "Новичок",
                    1 => "1 год опыта",
                    2 or 3 or 4 => $"{yearsOfExperience} года опыта",
                    _ => $"{yearsOfExperience} лет опыта"
                };
                
                <article class="card master-card">
                    <div class="master-card__header">
                        @if (!string.IsNullOrEmpty(master.AvatarPath))
                        {
                            <img class="master-card__avatar" src="@master.AvatarPath" alt="@master.Persona.FullName" />
                        }
                        else
                        {
                            <div class="master-card__avatar master-card__avatar--placeholder">
                                @(master.Persona.LastName.Length > 0 ? master.Persona.LastName[0].ToString() : "?")@(master.Persona.FirstName.Length > 0 ? master.Persona.FirstName[0].ToString() : "")
                            </div>
                        }
                        <div class="master-card__info">
                            <h3 class="master-card__name">@master.Persona.FullName</h3>
                            <p class="master-card__experience faint">@experienceText</p>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrWhiteSpace(master.Bio))
                    {
                        <p class="master-card__bio muted">@master.Bio</p>
                    }
                    
                    @if (master.MasterServices.Any())
                    {
                        <div class="master-card__services">
                            @foreach (var ms in master.MasterServices)
                            {
                                <span class="master-card__service-tag">@ms.Service.Name</span>
                            }
                        </div>
                    }
                </article>
            }
        </div>
    }
</section>

<p style="margin-top: var(--space-5);"><a asp-page="/Branches/Index">← Все филиалы</a></p>

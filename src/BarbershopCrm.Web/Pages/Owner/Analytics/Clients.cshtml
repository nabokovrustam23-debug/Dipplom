@page "/Owner/Analytics/Clients"
@model BarbershopCrm.Web.Pages.Owner.Analytics.ClientsModel
@{
    ViewData["Title"] = "Аналитика и сегментация клиентов — Тихого Часа";
    ViewData["ManagementTab"] = "analytics";
}

<partial name="_ManagementTabs" />

<section class="analytics-header">
    <div class="analytics-header__content">
        <span class="analytics-header__badge">Маркетинговый анализ</span>
        <h2>Сегментация и клиентская база</h2>
        <p class="analytics-header__subtitle">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/>
            </svg>
            <span>Глубокий анализ аудитории филиала @(Model.Snapshot?.BranchName ?? "Вся сеть")</span>
        </p>
    </div>
    <div class="management-header__actions">
        <a asp-page="/Owner/Analytics/Index"
           asp-route-from="@Model.FromValue.ToString("yyyy-MM-dd")"
           asp-route-to="@Model.ToValue.ToString("yyyy-MM-dd")"
           asp-route-branchid="@Model.BranchId"
           class="btn btn--outline btn--with-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            <span>К общим метрикам</span>
        </a>
    </div>
</section>

<div class="analytics-controls-layout">
    
    <section class="analytics-filters-card">
        <div class="analytics-filters-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
            </svg>
            <h3>Параметры когорты</h3>
        </div>
        <form method="get" class="analytics-filters" id="clientsFilterForm">
            <div class="filter-group">
                <label for="BranchId"><span>Филиал сети</span></label>
                <select id="BranchId" name="BranchId" class="input input--filter">
                    <option value="">Вся сеть барбершопов</option>
                    @foreach (var b in Model.BranchOptions)
                    {
                        <option value="@b.Value" selected="@(Model.BranchId?.ToString() == b.Value)">@b.Text</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label for="From"><span>Дата с</span></label>
                <input id="From" name="From" type="date" class="input input--filter" value="@Model.FromValue.ToString("yyyy-MM-dd")" />
            </div>
            <div class="filter-group">
                <label for="To"><span>Дата по</span></label>
                <input id="To" name="To" type="date" class="input input--filter" value="@Model.ToValue.ToString("yyyy-MM-dd")" />
            </div>
            <div class="filter-actions">
                <button type="submit" class="btn btn--accent btn--filter">
                    <span>Сформировать</span>
                </button>
                <a asp-page="/Owner/Analytics/Clients" class="btn btn--ghost btn--filter" title="Сбросить фильтры">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M23 4v6h-6M1 20v-6h6"></path>
                        <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                    </svg>
                </a>
            </div>
        </form>
    </section>

    <section class="export-banner-mini export-banner-mini--clients">
        <div class="export-banner-mini__content">
            <div class="export-banner-mini__text">
                <h4>Выгрузка CRM-профилей клиентов</h4>
                <p>Экспорт включает ФИО, телефоны, email, ABC-категории, уровни лояльности, предпочитаемых мастеров и объемы кассы.</p>
            </div>
        </div>
        <a asp-page="/Owner/Analytics/Clients" asp-page-handler="Export"
           asp-route-from="@Model.FromValue.ToString("yyyy-MM-dd")"
           asp-route-to="@Model.ToValue.ToString("yyyy-MM-dd")"
           asp-route-branchid="@Model.BranchId"
           class="btn btn--outline-success btn--export">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Скачать базу (.CSV)</span>
        </a>
    </section>
</div>

@if (Model.Snapshot is not null)
{
    <div class="kpi-mini-row">
        <div class="kpi-mini-card">
            <span class="kpi-mini-card__label">Активная база за период</span>
            <div class="kpi-mini-card__value-box">
                <span class="kpi-mini-card__value">@Model.Snapshot.TotalClients</span>
                <span class="kpi-mini-card__hint">уникальных гостей у кресла</span>
            </div>
        </div>
    </div>

    <section class="visual-chart-box visual-chart-box--full animate-fade-in">
        <div class="visual-chart-box__header">
            <div class="header-icon-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="1" x2="12" y2="23"></line>
                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
                <h4>Классический ABC-анализ клиентских сегментов</h4>
            </div>
            <p class="visual-chart-box__hint">Разделение базы по степени финансового вклада в общую кассу салона</p>
        </div>

        @{
            var pctA = Model.Snapshot.AbcDistribution.CategoryARevenuePercent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
            var pctB = Model.Snapshot.AbcDistribution.CategoryBRevenuePercent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
            var pctC = Model.Snapshot.AbcDistribution.CategoryCRevenuePercent.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
        }

        <div class="abc-stacked-visual-container">
            <div class="abc-stacked-bar">
                <div class="abc-stacked-segment segment-abc-a" style="width: @(pctA)%" title="Категория А: сформировала @(pctA)% кассы"></div>
                <div class="abc-stacked-segment segment-abc-b" style="width: @(pctB)%" title="Категория B: сформировала @(pctB)% кассы"></div>
                <div class="abc-stacked-segment segment-abc-c" style="width: @(pctC)%" title="Категория C: сформировала @(pctC)% кассы"></div>
            </div>
            <div class="abc-stacked-bar-legends">
                <span class="legend-item"><span class="legend-color block-abc-a"></span> Класс А (@(pctA)%)</span>
                <span class="legend-item"><span class="legend-color block-abc-b"></span> Класс B (@(pctB)%)</span>
                <span class="legend-item"><span class="legend-color block-abc-c"></span> Класс C (@(pctC)%)</span>
            </div>
        </div>

        <div class="abc-premium-grid">
            <div class="abc-p-card abc-p-card--a">
                <div class="abc-p-card__badge">Класс А</div>
                <h5 class="abc-p-card__title">Ядро / VIP-актив</h5>
                <p class="abc-p-card__desc">Генерируют львиную долю выручки. Требуют максимального удержания.</p>
                <div class="abc-p-card__metrics-row">
                    <div class="p-metric">
                        <small>Гостей</small>
                        <strong>@Model.Snapshot.AbcDistribution.CategoryACount</strong>
                    </div>
                    <div class="p-metric text-right">
                        <small>Принесли кассы</small>
                        <strong class="text-color-green">@Model.Snapshot.AbcDistribution.CategoryARevenue.ToString("N0") ₽</strong>
                    </div>
                </div>
            </div>

            <div class="abc-p-card abc-p-card--b">
                <div class="abc-p-card__badge">Класс B</div>
                <h5 class="abc-p-card__title">Стабильная опора</h5>
                <p class="abc-p-card__desc">Ходят умеренно, платят стабильно. Потенциал для перевода в категорию А.</p>
                <div class="abc-p-card__metrics-row">
                    <div class="p-metric">
                        <small>Гостей</small>
                        <strong>@Model.Snapshot.AbcDistribution.CategoryBCount</strong>
                    </div>
                    <div class="p-metric text-right">
                        <small>Принесли кассы</small>
                        <strong class="text-color-blue">@Model.Snapshot.AbcDistribution.CategoryBRevenue.ToString("N0") ₽</strong>
                    </div>
                </div>
            </div>

            <div class="abc-p-card abc-p-card--c">
                <div class="abc-p-card__badge">Класс C</div>
                <h5 class="abc-p-card__title">Разовые / Новички</h5>
                <p class="abc-p-card__desc">Низкий чек или редкие заходы. Много спящих клиентов или случайных стрижек.</p>
                <div class="abc-p-card__metrics-row">
                    <div class="p-metric">
                        <small>Гостей</small>
                        <strong>@Model.Snapshot.AbcDistribution.CategoryCCount</strong>
                    </div>
                    <div class="p-metric text-right">
                        <small>Принесли кассы</small>
                        <strong class="text-color-orange">@Model.Snapshot.AbcDistribution.CategoryCRevenue.ToString("N0") ₽</strong>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="visual-chart-box visual-chart-box--full">
        <div class="visual-chart-box__header">
            <h4>Распределение базы по накопленным грейдам лояльности</h4>
            <p class="visual-chart-box__hint">Разделение аудитории на основе исторического объема выполненных сессий</p>
        </div>
        <div class="premium-tier-dashboard-grid">
            <div class="premium-tier-card tier-border-new">
                <div class="premium-tier-card__icon icon-bg-new">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
                <div class="premium-tier-card__meta">
                    <span class="tier-name">Новые клиенты</span>
                    <span class="tier-condition">1 выполненный визит</span>
                </div>
                <div class="premium-tier-card__count text-color-new">@Model.Snapshot.TierDistribution.NewCount</div>
            </div>

            <div class="premium-tier-card tier-border-regular">
                <div class="premium-tier-card__icon icon-bg-regular">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <div class="premium-tier-card__meta">
                    <span class="tier-name">Постоянные</span>
                    <span class="tier-condition">От 2 до 5 визитов</span>
                </div>
                <div class="premium-tier-card__count text-color-regular">@Model.Snapshot.TierDistribution.RegularCount</div>
            </div>

            <div class="premium-tier-card tier-border-loyal">
                <div class="premium-tier-card__icon icon-bg-loyal">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </div>
                <div class="premium-tier-card__meta">
                    <span class="tier-name">Лояльные</span>
                    <span class="tier-condition">От 6 до 10 визитов</span>
                </div>
                <div class="premium-tier-card__count text-color-loyal">@Model.Snapshot.TierDistribution.LoyalCount</div>
            </div>

            <div class="premium-tier-card tier-border-vip">
                <div class="premium-tier-card__icon icon-bg-vip">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 19l2-14 4 6 4-6 4 6 4-6 2 14H2z"/><path d="M7 19l2-6 3 2 3-2 2 6"/></svg>
                </div>
                <div class="premium-tier-card__meta">
                    <span class="tier-name">Премиум / VIP</span>
                    <span class="tier-condition">11 и более визитов</span>
                </div>
                <div class="premium-tier-card__count text-color-vip">@Model.Snapshot.TierDistribution.VipCount</div>
            </div>
        </div>
    </section>

    <section class="visual-chart-box visual-chart-box--full">
        <div class="visual-chart-box__header">
            <div class="header-icon-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/>
                </svg>
                <h4>Рейтинговый журнал: ТОП-20 ключевых клиентов</h4>
            </div>
            <p class="visual-chart-box__hint">Список клиентов с наивысшим чеком и накопленным объемом инвестиций в сеть за период</p>
        </div>

        @if (Model.Snapshot.TopClients.Any())
        {
            <div class="premium-table-container">
                <table class="premium-table premium-table--crm-clients">
                    <thead>
                        <tr>
                            <th style="width: 70px; text-align: center;">Класс</th>
                            <th style="width: 120px;">Грейд</th>
                            <th>ФИО Клиента</th>
                            <th>Контакты связи</th>
                            <th style="text-align: center;">Визиты</th>
                            <th style="text-align: right;">Суммарная касса</th>
                            <th style="text-align: right;">Ср. чек</th>
                            <th style="width: 150px;">Последний сеанс</th>
                            <th>Постоянный фокус</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var client in Model.Snapshot.TopClients)
                        {
                            <tr>
                                <td style="text-align: center;">
                                    <span class="badge-abc-pill badge-abc-pill--@(client.AbcCategory.ToString().ToLower())">
                                        @client.AbcCategory
                                    </span>
                                </td>
                                
                                <td>
                                    <span class="badge-tier-pill badge-tier-pill--@(client.Tier.ToString().ToLower())">
                                        @switch (client.Tier)
                                        {
                                            case BarbershopCrm.Infrastructure.Analytics.ClientTier.New:
                                                @:Новый
                                                break;
                                            case BarbershopCrm.Infrastructure.Analytics.ClientTier.Regular:
                                                @:Постоянный
                                                break;
                                            case BarbershopCrm.Infrastructure.Analytics.ClientTier.Loyal:
                                                @:Лояльный
                                                break;
                                            case BarbershopCrm.Infrastructure.Analytics.ClientTier.VIP:
                                                @:VIP
                                                break;
                                        }
                                    </span>
                                </td>
                                
                                <td>
                                    <div class="table-client-profile">
                                        <div class="table-client-avatar">
                                            @(string.IsNullOrEmpty(client.ClientName) ? "?" : client.ClientName.Substring(0, 1).ToUpper())
                                        </div>
                                        <strong class="table-client-name-text">@client.ClientName</strong>
                                    </div>
                                </td>
                                
                                <td class="table-contacts-cell">
                                    @if (!string.IsNullOrEmpty(client.Phone))
                                    {
                                        <div class="contact-sub-item">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                            <span>@client.Phone</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(client.Email))
                                    {
                                        <div class="contact-sub-item contact-sub-item--email">
                                            <span>@client.Email</span>
                                        </div>
                                    }
                                </td>
                                
                                <td style="text-align: center;" class="table-numeric-bold">
                                    @client.TotalVisits
                                </td>
                                
                                <td style="text-align: right;" class="table-currency-highlight">
                                    @client.TotalRevenue.ToString("N0") ₽
                                </td>
                                
                                <td style="text-align: right;" class="table-numeric-gray-bold">
                                    @client.AverageTicket.ToString("N0") ₽
                                </td>
                                
                                <td>
                                    <div class="table-visit-timeline">
                                        <span class="timeline-exact-date">@client.LastVisitDate.ToString("dd.MM.yyyy")</span>
                                        <span class="timeline-days-ago">@client.DaysSinceLastVisit дн. назад</span>
                                    </div>
                                </td>
                                
                                <td>
                                    <div class="table-preferences-stack">
                                        @if (!string.IsNullOrEmpty(client.PreferredMaster))
                                        {
                                            <span class="pref-tag pref-tag--master" title="Любимый мастер барбершопа">
                                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                                @client.PreferredMaster
                                            </span>
                                        }
                                        @if (!string.IsNullOrEmpty(client.PreferredService))
                                        {
                                            <span class="pref-tag pref-tag--service" title="Частая услуга">
                                                @client.PreferredService
                                            </span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="visual-chart-box__empty">
                <p>Выбранные сегменты пусты. Нет данных о клиентах за указанный период времени.</p>
            </div>
        }
    </section>
}

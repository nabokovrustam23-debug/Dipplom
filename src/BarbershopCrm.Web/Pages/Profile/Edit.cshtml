@page
@model BarbershopCrm.Web.Pages.Profile.EditModel
@{
    ViewData["Title"] = "Редактировать профиль";
}

<section class="profile-edit-section">
    <div class="profile-edit-header">
        <div>
            <h1>Редактировать профиль</h1>
            <p class="muted">Обновите свои личные данные. Дата рождения используется для акции «День рождения».</p>
        </div>
        <a asp-page="/Profile/Index" class="btn btn--ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Назад к профилю
        </a>
    </div>

    <form method="post" class="profile-edit-form" data-busy>
        <div class="card profile-edit-card">
            <div class="profile-edit-section-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg>
                <h2>Личные данные</h2>
            </div>

            <div class="form-grid">
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.LastName">
                            Фамилия
                            <span class="required-mark">*</span>
                        </label>
                        <input asp-for="Input.LastName" 
                               class="input" 
                               required 
                               placeholder="Иванов"
                               autocomplete="family-name" />
                        <span asp-validation-for="Input.LastName" class="field-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.FirstName">
                            Имя
                            <span class="required-mark">*</span>
                        </label>
                        <input asp-for="Input.FirstName" 
                               class="input" 
                               required 
                               placeholder="Иван"
                               autocomplete="given-name" />
                        <span asp-validation-for="Input.FirstName" class="field-error"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Input.MiddleName">Отчество</label>
                    <input asp-for="Input.MiddleName" 
                           class="input" 
                           placeholder="Иванович (необязательно)"
                           autocomplete="additional-name" />
                    <span asp-validation-for="Input.MiddleName" class="field-error"></span>
                </div>
            </div>
        </div>

        <div class="card profile-edit-card">
            <div class="profile-edit-section-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
                <h2>Контактная информация</h2>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Input.Phone">
                        Телефон
                        <span class="required-mark">*</span>
                    </label>
                    <div class="input-with-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                        </svg>
                        <input asp-for="Input.Phone" 
                               type="tel" 
                               class="input input--with-icon" 
                               required 
                               placeholder="+7 (999) 123-45-67"
                               autocomplete="tel" />
                    </div>
                    <span asp-validation-for="Input.Phone" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Email">Email</label>
                    <div class="input-with-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                        <input asp-for="Input.Email" 
                               type="email" 
                               class="input input--with-icon" 
                               placeholder="example@mail.ru"
                               autocomplete="email" />
                    </div>
                    <span asp-validation-for="Input.Email" class="field-error"></span>
                </div>
            </div>
        </div>

        <div class="card profile-edit-card">
            <div class="profile-edit-section-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                <h2>Дополнительно</h2>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Input.BirthDate">Дата рождения</label>
                    <div class="input-with-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 7h-3V4a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v3H4a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"></path>
                            <path d="M12 12v5"></path>
                            <path d="M12 12h5"></path>
                        </svg>
                        <input asp-for="Input.BirthDate" 
                               type="date" 
                               class="input input--with-icon" 
                               autocomplete="bday" />
                    </div>
                    <span asp-validation-for="Input.BirthDate" class="field-error"></span>
                    <small class="form-hint">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 7h-3V4a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v3H4a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"></path>
                            <path d="M12 12v5"></path>
                            <path d="M12 12h5"></path>
                        </svg>
                        Укажите дату рождения, чтобы получать специальную скидку в день рождения!
                    </small>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                Сохранить изменения
            </button>
            <a asp-page="/Profile/Index" class="btn btn--outline">Отмена</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


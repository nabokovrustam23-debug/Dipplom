@using BarbershopCrm.Domain.Enums
@model BarbershopCrm.Web.Pages.Shared.ScheduleAgendaViewModel
@{
    var postPage = Model.FormTarget == ScheduleAgendaFormTarget.AdminSchedule ? "/Admin/Schedule" : "/Master/Bookings";
}
<div class="schedule-agenda">
    @foreach (var sec in Model.Masters)
    {
        <section class="schedule-agenda__master-card">
            <header class="schedule-agenda__master-head">
                <span class="schedule-agenda__avatar" aria-hidden="true">@sec.Initial</span>
                <h3 class="schedule-agenda__master-name">@sec.Name</h3>
            </header>
            @if (sec.Items.Count == 0)
            {
                <p class="schedule-agenda__empty muted">На этот день нет событий.</p>
            }
            else
            {
                <ul class="schedule-agenda__list">
                    @foreach (var item in sec.Items)
                    {
                        if (item is ScheduleAgendaBookingItem row)
                        {
                            var b = row.Booking;
                            var st = b.Status.ToLowerInvariant();
                            <li class="schedule-agenda__item">
                                <div class="schedule-agenda__row schedule-agenda__row--booking">
                                    <div class="schedule-agenda__time-col">
                                        <span class="schedule-agenda__time-main">@b.StartDateTime.ToString("HH:mm")</span>
                                        <span class="schedule-agenda__time-sub">@b.StartDateTime.AddMinutes(b.DurationMinutes).ToString("HH:mm")</span>
                                    </div>
                                    <div class="schedule-agenda__body schedule-agenda__body--@st">
                                        <div class="schedule-agenda__body-top">
                                            <span class="schedule-agenda__client">@b.Client.Persona.ShortName</span>
                                            <span class="schedule-agenda__badge schedule-agenda__badge--@st">@row.StatusLabel</span>
                                        </div>
                                        <div class="schedule-agenda__service">@b.Service.Name</div>
                                        <div class="schedule-agenda__meta-line muted">
                                            @b.PriceSnapshot.ToString("0") ₽
                                            @if (b.LoyaltyDiscountPercent > 0)
                                            {
                                                <span class="schedule-agenda__badge schedule-agenda__badge--discount">-@b.LoyaltyDiscountPercent%</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(b.Client.Persona.Phone))
                                            {
                                                <span class="schedule-agenda__sep">·</span>
                                                <span class="tnum">@b.Client.Persona.Phone</span>
                                            }
                                        </div>
                                        <div class="schedule-agenda__row-actions">
                                            <button type="button" class="btn btn--outline btn--small" onclick="document.getElementById('schedule-agenda-dlg-@b.BookingId').showModal()">Управление</button>
                                        </div>
                                    </div>
                                </div>

                                <dialog class="schedule-agenda__dialog" id="schedule-agenda-dlg-@b.BookingId" aria-labelledby="schedule-agenda-dlg-title-@b.BookingId">
                                    <div class="schedule-agenda__dialog-inner">
                                        <header class="schedule-agenda__dialog-head">
                                            <h2 class="schedule-agenda__dialog-title" id="schedule-agenda-dlg-title-@b.BookingId">@b.Client.Persona.ShortName</h2>
                                            <button type="button" class="schedule-agenda__dialog-close" onclick="document.getElementById('schedule-agenda-dlg-@b.BookingId').close()" aria-label="Закрыть">
                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <line x1="18" y1="6" x2="6" y2="18"></line>
                                                    <line x1="6" y1="6" x2="18" y2="18"></line>
                                                </svg>
                                            </button>
                                        </header>
                                        
                                        <div asp-validation-summary="All" class="alert alert--error" style="margin-top: 1rem;"></div>
                                        
                                        <div class="schedule-agenda__dialog-info">
                                            <div class="schedule-agenda__dialog-info-item">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <circle cx="12" cy="12" r="10"></circle>
                                                    <polyline points="12 6 12 12 16 14"></polyline>
                                                </svg>
                                                <span>@b.StartDateTime.ToString("HH:mm")–@b.StartDateTime.AddMinutes(b.DurationMinutes).ToString("HH:mm")</span>
                                            </div>
                                            <div class="schedule-agenda__dialog-info-item">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                                                    <line x1="7" y1="7" x2="7.01" y2="7"></line>
                                                </svg>
                                                <span>@b.Service.Name</span>
                                            </div>
                                        </div>

                                        <div class="schedule-agenda__dialog-status">
                                            <span class="schedule-agenda__badge schedule-agenda__badge--@st">@row.StatusLabel</span>
                                        </div>

                                        @if (Model.FormTarget == ScheduleAgendaFormTarget.AdminSchedule && Model.BranchId.HasValue)
                                        {
                                            <div class="schedule-agenda__dialog-link-section">
                                                <a class="schedule-agenda__dialog-link" href="/Admin/Bookings?BookingId=@b.BookingId&amp;BranchId=@Model.BranchId.Value">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                                                        <polyline points="15 3 21 3 21 9"></polyline>
                                                        <line x1="10" y1="14" x2="21" y2="3"></line>
                                                    </svg>
                                                    Открыть в журнале записей
                                                </a>
                                            </div>
                                        }

                                        @if (ScheduleAgendaRules.CanConfirm(b) || ScheduleAgendaRules.CanCancel(b) || ScheduleAgendaRules.CanCompleteOrNoShow(b))
                                        {
                                            <div class="schedule-agenda__dialog-actions">
                                                @if (ScheduleAgendaRules.CanConfirm(b))
                                                {
                                                    <form method="post" asp-page="@postPage" asp-page-handler="Confirm" asp-route-id="@b.BookingId" data-busy>
                                                        @if (Model.FormTarget == ScheduleAgendaFormTarget.AdminSchedule && Model.BranchId.HasValue)
                                                        {
                                                            <input type="hidden" name="BranchId" value="@Model.BranchId.Value" />
                                                        }
                                                        <input type="hidden" name="Date" value="@Model.DateParam" />
                                                        <button class="btn btn--primary" type="submit">
                                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                <polyline points="20 6 9 17 4 12"></polyline>
                                                            </svg>
                                                            Подтвердить
                                                        </button>
                                                    </form>
                                                }
                                                @if (ScheduleAgendaRules.CanCompleteOrNoShow(b))
                                                {
                                                    <form method="post" asp-page="@postPage" asp-page-handler="NoShow" asp-route-id="@b.BookingId" data-busy onsubmit="return confirm('Отметить, что клиент не пришёл?');">
                                                        @if (Model.FormTarget == ScheduleAgendaFormTarget.AdminSchedule && Model.BranchId.HasValue)
                                                        {
                                                            <input type="hidden" name="BranchId" value="@Model.BranchId.Value" />
                                                        }
                                                        <input type="hidden" name="Date" value="@Model.DateParam" />
                                                        <button class="btn btn--outline" type="submit">
                                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                <circle cx="12" cy="12" r="10"></circle>
                                                                <line x1="15" y1="9" x2="9" y2="15"></line>
                                                                <line x1="9" y1="9" x2="15" y2="15"></line>
                                                            </svg>
                                                            Не пришёл
                                                        </button>
                                                    </form>
                                                    
                                                    <div class="schedule-agenda__complete-section">
                                                        <form method="post" asp-page="@postPage" asp-page-handler="Complete" class="schedule-agenda__complete-form" data-busy>
                                                            @if (Model.FormTarget == ScheduleAgendaFormTarget.AdminSchedule && Model.BranchId.HasValue)
                                                            {
                                                                <input type="hidden" name="BranchId" value="@Model.BranchId.Value" />
                                                            }
                                                            <input type="hidden" name="Date" value="@Model.DateParam" />
                                                            <input type="hidden" name="Complete.BookingId" value="@b.BookingId" />
                                                            @{
                                                                var finalAmount = b.PriceSnapshot * (1 - b.LoyaltyDiscountPercent / 100m);
                                                                var hasDiscount = b.LoyaltyDiscountPercent > 0;
                                                                var discountReasonText = hasDiscount ? b.LoyaltyDiscountReason switch
                                                                {
                                                                    "Tier" => "Уровень лояльности",
                                                                    "Birthday" => "День рождения",
                                                                    "FirstVisit" => "Первый визит",
                                                                    _ => null
                                                                } : null;
                                                            }
                                                            <div class="form-group">
                                                                <span class="schedule-agenda__complete-amount">
                                                                    Сумма: <strong>@finalAmount.ToString("0") ₽</strong>
                                                                    @if (hasDiscount)
                                                                    {
                                                                        <small class="form-hint">
                                                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                                <circle cx="12" cy="12" r="10"></circle>
                                                                                <path d="M12 16v-4"></path>
                                                                                <path d="M12 8h.01"></path>
                                                                            </svg>
                                                                            @b.PriceSnapshot.ToString("0") ₽ · скидка @b.LoyaltyDiscountPercent%@(discountReasonText != null ? $" · {discountReasonText}" : "")
                                                                        </small>
                                                                    }
                                                                </span>
                                                            </div>
                                                            <div class="form-group">
                                                                <label for="dlg-notes-@b.BookingId">Заметки</label>
                                                                <textarea id="dlg-notes-@b.BookingId" name="Complete.MasterNotes" maxlength="500" class="input" rows="3" placeholder="Комментарии о визите (необязательно)"></textarea>
                                                            </div>
                                                            <button class="btn btn--primary" type="submit">
                                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                    <polyline points="20 6 9 17 4 12"></polyline>
                                                                </svg>
                                                                Завершить визит
                                                            </button>
                                                        </form>
                                                    </div>
                                                }
                                                @if (ScheduleAgendaRules.CanCancel(b))
                                                {
                                                    <form method="post" asp-page="@postPage" asp-page-handler="Cancel" asp-route-id="@b.BookingId" data-busy onsubmit="return confirm('Отменить запись?');">
                                                        @if (Model.FormTarget == ScheduleAgendaFormTarget.AdminSchedule && Model.BranchId.HasValue)
                                                        {
                                                            <input type="hidden" name="BranchId" value="@Model.BranchId.Value" />
                                                        }
                                                        <input type="hidden" name="Date" value="@Model.DateParam" />
                                                        <button class="btn btn--outline" type="submit">
                                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                                                <line x1="6" y1="6" x2="18" y2="18"></line>
                                                            </svg>
                                                            Отменить
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        }

                                        @if ((ScheduleAgendaRules.CanConfirm(b) || ScheduleAgendaRules.CanCancel(b)) && !ScheduleAgendaRules.CanCompleteOrNoShow(b) && (b.Status == BookingStatus.Created || b.Status == BookingStatus.Confirmed))
                                        {
                                            <div class="schedule-agenda__dialog-hint">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <circle cx="12" cy="12" r="10"></circle>
                                                    <path d="M12 16v-4"></path>
                                                    <path d="M12 8h.01"></path>
                                                </svg>
                                                <span>«Не пришёл» и «Завершить визит» будут доступны с @b.StartDateTime.ToString("HH:mm") (по времени записи).</span>
                                            </div>
                                        }

                                        @if (!ScheduleAgendaRules.CanConfirm(b) && !ScheduleAgendaRules.CanCancel(b) && !ScheduleAgendaRules.CanCompleteOrNoShow(b))
                                        {
                                            <div class="schedule-agenda__dialog-hint">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <circle cx="12" cy="12" r="10"></circle>
                                                    <path d="M12 16v-4"></path>
                                                    <path d="M12 8h.01"></path>
                                                </svg>
                                                <span>Для этой записи нет доступных действий.</span>
                                            </div>
                                        }
                                    </div>
                                </dialog>
                            </li>
                        }
                        else if (item is ScheduleAgendaBreakItem br)
                        {
                            <li class="schedule-agenda__row schedule-agenda__row--break">
                                <div class="schedule-agenda__time-col">
                                    <span class="schedule-agenda__time-main">@br.Start.ToString("HH:mm")</span>
                                    <span class="schedule-agenda__time-sub">@br.End.ToString("HH:mm")</span>
                                </div>
                                <div class="schedule-agenda__break schedule-break schedule-break--@br.ModifierCss">
                                    <span class="schedule-break__label">@br.Label</span>
                                    <span class="schedule-break__time">@br.Start.ToString("HH:mm") – @br.End.ToString("HH:mm")</span>
                                </div>
                            </li>
                        }
                    }
                </ul>
            }
        </section>
    }
</div>


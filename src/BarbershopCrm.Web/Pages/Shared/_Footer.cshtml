@using BarbershopCrm.Domain.Enums
@using BarbershopCrm.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext FooterDb
@inject ICurrentUserAccessor FooterCurrent
@{
    var year = DateTime.UtcNow.Year;
    var current = FooterCurrent.User;
    var branches = await FooterDb.Branches
        .AsNoTracking()
        .Where(b => b.IsActive)
        .OrderBy(b => b.Name)
        .Select(b => new { b.BranchId, b.Name, b.Address, b.Phone, b.OpeningTime, b.ClosingTime })
        .Take(4)
        .ToListAsync();
}

<footer class="site-footer-premium" role="contentinfo">
    <div class="site-footer-premium__inner">
        
        <div class="site-footer-premium__col site-footer-premium__col--brand">
            <div class="footer-brand-wrapper">
                <img src="~/images/logo.svg" class="footer-brand-icon-img" width="40" height="40" alt="Тихий час" />
                <div class="footer-brand-title-text">Тихий час</div>
            </div>
            <p class="footer-brand-lead-speech">Премиальная краснодарская сеть мужских парикмахерских. Профессиональный уход, классические стрижки и современная автоматизированная CRM-система онлайн-контроля записей.</p>
        </div>

        <div class="site-footer-premium__col">
            <h5>Карта разделов</h5>
            <ul class="footer-links-list-nodes">
                <li><a asp-page="/Index">Главная страница</a></li>
                <li><a asp-page="/Branches/Index">Действующие филиалы</a></li>
                <li><a asp-page="/Services/Index">Услуги и прейскурант</a></li>
                
                @if (current is not null && current.RoleCode == RoleCode.Client)
                {
                    <li><a asp-page="/BookingFlow/New">Онлайн-бронирование</a></li>
                    <li><a asp-page="/Account/Bookings/Index">Журнал моих записей</a></li>
                }
                else if (current is null)
                {
                    <li><a asp-page="/Lead/Index">Отправить заявку</a></li>
                    <li><a asp-page="/Account/Login">Вход в личный кабинет</a></li>
                }
            </ul>
        </div>

        <div class="site-footer-premium__col">
            <h5>Локации филиалов</h5>
            <ul class="footer-links-list-nodes footer-branches-list-nodes">
                @foreach (var b in branches)
                {
                    <li class="footer-branch-item-node">
                        <a asp-page="/Branches/Details" asp-route-id="@b.BranchId" class="f-branch-name">@b.Name</a>
                        <span class="f-branch-address">@b.Address</span>
                        <div class="f-branch-meta-row tnum">
                            @if (!string.IsNullOrWhiteSpace(b.Phone))
                            {
                                <a class="f-branch-phone" href="tel:@b.Phone.Replace(" ", "").Replace("(", "").Replace(")", "").Replace("-", "")">@b.Phone</a>
                            }
                            <span class="f-branch-hours">@b.OpeningTime.ToString("HH:mm")–@b.ClosingTime.ToString("HH:mm")</span>
                        </div>
                    </li>
                }
            </ul>
        </div>

        <div class="site-footer-premium__col">
            <h5>Центральный офис</h5>
            <ul class="footer-links-list-nodes">
                <li><a href="tel:+78612345678" class="tnum" style="font-weight:600; font-size: 1.05rem; color: var(--color-text-main);">+7 (861) 234-56-78</a></li>
                <li><a href="mailto:info@tihiychas.ru">info@tihiychas.ru</a></li>
                <li style="margin-top: 1rem;"><small style="color: var(--color-text-muted); text-transform: uppercase; font-size: 0.7rem; font-weight:600; letter-spacing: 0.5px;">Центральный режим</small></li>
                <li class="tnum" style="font-size: 0.9rem; color: var(--color-text-main);">Ежедневно с 10:00 до 22:00</li>
            </ul>
        </div>
    </div>

    <div class="site-footer-premium__bottom">
        <span>© @year Сеть барбершопов «Тихий час». Все права защищены.</span>
        <span class="site-footer-premium__sep">·</span>
        <a asp-page="/Privacy">Политика конфиденциальности по 152-ФЗ</a>
    </div>
</footer>

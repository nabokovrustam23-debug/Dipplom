@page
@model BarbershopCrm.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Вход в кабинет — Тихого Часа";
    Layout = "_AuthLayout";
}

<section class="auth-split animate-fade-in">
    <aside class="auth-split__hero" aria-hidden="true">
        <div class="auth-split__hero-overlay">
            <a asp-page="/Index" class="auth-split__brand">
                <img src="~/images/logo.svg" alt="Тихий час" class="auth-split__brand-logo" width="48" height="48" />
                <div class="auth-split__brand-text">
                    <span class="auth-split__brand-mark">Тихий час</span>
                    <span class="auth-split__brand-tag">Барбершоп · Краснодар</span>
                </div>
            </a>
            
            <div class="auth-split__hero-body">
                <div class="auth-split__quote">
                    <p>«Расписание, мастера и онлайн-запись в единой экосистеме. Управляйте сетью барбершопов спокойно — это и есть тихий час.»</p>
                </div>
                <ul class="auth-split__bullets">
                    <li>
                        <span class="bullet-dot"></span>
                        <span>Онлайн-запись клиентов с автоматической защитой от двойного бронирования</span>
                    </li>
                    <li>
                        <span class="bullet-dot"></span>
                        <span>Личный кабинет мастера: управление сменами, перерывами и отпусками</span>
                    </li>
                    <li>
                        <span class="bullet-dot"></span>
                        <span>Сводный журнал выполненных визитов и оперативное управление заявками</span>
                    </li>
                </ul>
            </div>
            
            <div class="auth-split__hero-foot faint">© @DateTime.Now.Year · Сеть барбершопов «Тихий час»</div>
        </div>
    </aside>

    <div class="auth-split__panel">
        <div class="auth-split__panel-inner">
            <header class="auth-split__header">
                <a asp-page="/Index" class="auth-split__back">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 4px; vertical-align: middle;">
                        <line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                    <span>На главную страницу</span>
                </a>
                <h1>С возвращением</h1>
                <p class="muted">Войдите в учетную запись компании, чтобы продолжить работу.</p>
            </header>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert--error alert--modern" style="margin-bottom: 1.5rem;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line></svg>
                    <span>@Model.ErrorMessage</span>
                </div>
            }

            <form method="post" novalidate class="auth-form">
                <input asp-for="ReturnUrl" type="hidden" />

                <div class="field auth-field" style="margin-bottom: 1.25rem;">
                    <label asp-for="Input.Email" class="auth-field__label">Электронная почта (Email)</label>
                    <div class="input-with-icon-layout">
                        <span class="search-icon-inside" style="font-size: 0.9rem; color: var(--color-text-muted); font-weight: 500;">@@</span>
                        <input asp-for="Input.Email" type="email" autocomplete="username" class="input input--hub" style="padding-left: 36px;" autofocus required placeholder="ivan@example.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="field-error"></span>
                </div>

                <div class="field auth-field" style="margin-bottom: 2rem;">
                    <label asp-for="Input.Password" class="auth-field__label" style="display: flex; justify-content: space-between; width: 100%;">
                        <span>Пароль доступа</span>
                        <a asp-page="/Account/ForgotPassword" class="auth-field__hint" style="font-size: 0.85rem; color: var(--color-primary); text-decoration: none;">Забыли пароль?</a>
                    </label>
                    <div class="input-with-icon-layout">
                        <span class="search-icon-inside" style="font-size: 0.7rem; color: var(--color-text-muted); vertical-align: middle;">●</span>
                        <input asp-for="Input.Password" type="password" autocomplete="current-password" class="input input--hub" style="padding-left: 36px;" required placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Input.Password" class="field-error"></span>
                </div>

                <button type="submit" class="btn btn--primary btn--full-width">
                    <span>Войти в личный кабинет</span>
                </button>
            </form>

            <div class="auth-split__divider" style="margin: 2rem 0;"><span>или</span></div>

            <p class="auth-split__signup" style="text-align: center; color: var(--color-text-muted);">
                Ещё нет профиля в сети? <a asp-page="/Account/Register" style="color: var(--color-primary); font-weight: 600; text-decoration: none;">Создать аккаунт гостя</a>
            </p>

            @if (Model.ShowQuickLogin)
            {
                <details class="quick-login auth-split__quick" style="margin-top: 3rem; border-top: 1px dashed var(--color-border); padding-top: 1.5rem;">
                    <summary class="quick-login__summary" style="cursor: pointer; display: flex; align-items: center; justify-content: space-between;">
                        <span class="quick-login__title" style="font-weight: 600; font-size: 0.9rem; color: var(--color-text-main);">Быстрый демонстрационный вход</span>
                        <span class="badge badge--warning" style="font-size: 0.75rem; letter-spacing: 0.5px;">DEV MODE</span>
                    </summary>
                    <p class="faint quick-login__hint" style="margin: 0.5rem 0 1rem 0; font-size: 0.85rem;">Тестовые профили для мгновенной проверки сценариев защиты. Пароль: <code>Test12345!</code>.</p>
                    
                    <div class="quick-login-premium-grid" style="display: flex; flex-direction: column; gap: 0.75rem;">
                        @foreach (var acc in Model.QuickAccounts)
                        {
                            <form method="post" asp-page-handler="Quick" class="action-form-stretch">
                                <input type="hidden" name="email" value="@acc.Email" />
                                <input asp-for="ReturnUrl" type="hidden" />
                                <button type="submit" class="btn btn--outline btn--sm btn--full-width quick-demo-role-btn" style="text-align: left; display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 1rem;">
                                    <div style="display: flex; flex-direction: column; gap: 0.15rem;">
                                        <strong style="font-size: 0.85rem; color: var(--color-text-main);">@acc.Title</strong>
                                        <small style="font-size: 0.75rem; color: var(--color-text-muted);">@acc.Email</small>
                                    </div>
                                    <span class="badge badge--neutral" style="font-size: 0.75rem;">@acc.Subtitle</span>
                                </button>
                            </form>
                        }
                    </div>
                </details>
            }
        </div>
    </div>
</section>

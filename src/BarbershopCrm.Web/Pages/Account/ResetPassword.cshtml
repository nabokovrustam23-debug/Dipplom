@page
@model BarbershopCrm.Web.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Новый пароль";
}

<section class="auth-shell">
    <div class="auth-card card">
        @if (!Model.IsLinkValid)
        {
            <h1>Ссылка недействительна</h1>
            <p class="muted">@Model.ErrorMessage</p>
            <div class="auth-actions">
                <a asp-page="/Account/ForgotPassword" class="btn btn--primary">Запросить новую ссылку</a>
            </div>
        }
        else
        {
            <h1>Новый пароль</h1>
            <p class="muted">Введите новый пароль для аккаунта. После смены все активные сессии будут завершены.</p>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="flash flash--error">@Model.ErrorMessage</div>
            }

            <form method="post" novalidate>
                <input asp-for="Token" type="hidden" />

                <div class="field">
                    <label asp-for="Input.Password">Новый пароль</label>
                    <input asp-for="Input.Password" type="password" autocomplete="new-password" required autofocus />
                    <span asp-validation-for="Input.Password" class="field-error"></span>
                    <p class="faint">Не короче 8 символов.</p>
                </div>

                <div class="field">
                    <label asp-for="Input.PasswordRepeat">Повторите пароль</label>
                    <input asp-for="Input.PasswordRepeat" type="password" autocomplete="new-password" required />
                    <span asp-validation-for="Input.PasswordRepeat" class="field-error"></span>
                </div>

                <div class="auth-actions">
                    <button type="submit" class="btn btn--primary">Сохранить пароль</button>
                </div>
            </form>
        }
    </div>
</section>

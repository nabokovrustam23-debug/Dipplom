@page
@model BarbershopCrm.Web.Pages.Owner.Services.IndexModel
@{
    ViewData["Title"] = "Управление · Услуги";
    ViewData["ManagementTab"] = "services";
}

<partial name="_ManagementTabs" />

<section class="services-management">
    <div class="services-header">
        <div class="services-header__content">
            <h2>Прайс-лист услуг</h2>
            <p class="services-header__subtitle">Управление услугами и ценами</p>
        </div>
        <div class="services-header__stats">
            <div class="stat-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                    <line x1="7" y1="7" x2="7.01" y2="7"></line>
                </svg>
                <div class="stat-badge__content">
                    <div class="stat-badge__value">@Model.Services.Count</div>
                    <div class="stat-badge__label">Всего</div>
                </div>
            </div>
            <div class="stat-badge stat-badge--success">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <div class="stat-badge__content">
                    <div class="stat-badge__value">@Model.Services.Count(s => s.IsActive)</div>
                    <div class="stat-badge__label">Активных</div>
                </div>
            </div>
        </div>
        <a asp-page="Create" class="btn btn--primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Создать услугу
        </a>
    </div>

    <div class="services-filters card">
        <div class="services-filters__row">
            <div class="form-group services-filters__search">
                <label for="serviceSearch">Поиск</label>
                <div style="position: relative;">
                    <svg style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--color-text-muted); pointer-events: none;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.35-4.35"></path>
                    </svg>
                    <input id="serviceSearch" 
                           class="input" 
                           type="search" 
                           placeholder="например, борода или стрижка"
                           autocomplete="off" 
                           style="padding-left: 42px;" />
                </div>
            </div>
            <div class="form-group">
                <label for="sortSelect">Сортировка</label>
                <select id="sortSelect" class="input">
                    <option value="name">По названию</option>
                    <option value="price-asc">Цена: дешевле</option>
                    <option value="price-desc">Цена: дороже</option>
                    <option value="duration-asc">Длительность: короче</option>
                    <option value="duration-desc">Длительность: дольше</option>
                </select>
            </div>
        </div>

        <div class="services-filters__chips">
            <button type="button" class="chip chip--active" data-category="all">Все</button>
            <button type="button" class="chip" data-category="haircut">Стрижки</button>
            <button type="button" class="chip" data-category="beard">Борода</button>
            <button type="button" class="chip" data-category="shave">Бритьё</button>
        </div>

        <div class="services-filters__row services-filters__ranges">
            <div class="form-group">
                <label for="minPrice">Цена от, ₽</label>
                <input id="minPrice" class="input" type="number" min="0" step="50" inputmode="numeric" />
            </div>
            <div class="form-group">
                <label for="maxPrice">Цена до, ₽</label>
                <input id="maxPrice" class="input" type="number" min="0" step="50" inputmode="numeric" />
            </div>
            <div class="form-group">
                <label for="maxDuration">Длительность до, мин</label>
                <input id="maxDuration" class="input" type="number" min="0" step="5" inputmode="numeric" />
            </div>
            <div class="form-actions services-filters__actions">
                <button type="button" id="applyFilters" class="btn btn--primary">Применить</button>
            </div>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; padding-top: var(--space-3); border-top: 1px solid var(--color-border);">
            <label class="filter-checkbox">
                <input type="checkbox" id="hideInactiveServices" />
                <span>Скрыть неактивные</span>
            </label>
            <p class="services-summary" style="margin: 0;">
                Показано: <strong id="visibleCount">@Model.Services.Count</strong> из <strong>@Model.Services.Count</strong>
            </p>
        </div>
    </div>

    @if (Model.Services.Count == 0)
    {
        <div class="empty-state">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                <line x1="7" y1="7" x2="7.01" y2="7"></line>
            </svg>
            <h3>Нет услуг</h3>
            <p>Создайте первую услугу для прайс-листа</p>
            <a asp-page="Create" class="btn btn--primary">Создать услугу</a>
        </div>
    }
    else
    {
        <div class="services-grid" id="servicesGrid">
            @foreach (var s in Model.Services)
            {
                <div class="service-card @(s.IsActive ? "" : "service-card--inactive")" 
                     data-name="@s.Name.ToLower()" 
                     data-status="@(s.IsActive ? "active" : "inactive")"
                     data-price="@s.Price"
                     data-duration="@s.DurationMinutes"
                     data-category="@(s.Name.ToLower().Contains("стрижка") ? "haircut" : s.Name.ToLower().Contains("борода") ? "beard" : s.Name.ToLower().Contains("бритьё") || s.Name.ToLower().Contains("бритье") ? "shave" : "other")">
                    <div class="service-card__image">
                        @if (!string.IsNullOrEmpty(s.ImageUrl))
                        {
                            <img src="@s.ImageUrl" alt="@s.Name" loading="lazy" />
                        }
                        else
                        {
                            <div class="service-card__image-placeholder">
                                <img src="~/images/service-placeholder.svg" alt="" style="width:48px;height:48px;" />
                            </div>
                        }
                        <div class="service-card__status">
                            @if (s.IsActive)
                            {
                                <span class="badge badge--ok">Активна</span>
                            }
                            else
                            {
                                <span class="badge badge--warn">Скрыта</span>
                            }
                        </div>
                    </div>

                    <div class="service-card__content">
                        <h3 class="service-card__name">@s.Name</h3>
                        
                        @if (!string.IsNullOrEmpty(s.Description))
                        {
                            <p class="service-card__description">@s.Description</p>
                        }

                        <div class="service-card__info">
                            <div class="service-card__info-item">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <polyline points="12 6 12 12 16 14"></polyline>
                                </svg>
                                <span class="tnum">@s.DurationMinutes мин</span>
                            </div>

                            <div class="service-card__price">
                                <span class="tnum">@s.Price.ToString("0") ₽</span>
                            </div>
                        </div>
                    </div>

                    <div class="service-card__actions">
                        <a asp-page="Edit" asp-route-id="@s.ServiceId" class="btn btn--outline btn--sm">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                            </svg>
                            Изменить
                        </a>
                    </div>
                </div>
            }
        </div>

        <div id="noResults" class="empty-state" style="display: none;">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
            </svg>
            <h3>Ничего не найдено</h3>
            <p>Попробуйте изменить параметры поиска или фильтры</p>
        </div>
    }
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('serviceSearch');
            const hideInactiveCheckbox = document.getElementById('hideInactiveServices');
            const sortSelect = document.getElementById('sortSelect');
            const minPriceInput = document.getElementById('minPrice');
            const maxPriceInput = document.getElementById('maxPrice');
            const maxDurationInput = document.getElementById('maxDuration');
            const applyButton = document.getElementById('applyFilters');
            const categoryChips = document.querySelectorAll('.chip');
            const serviceCards = Array.from(document.querySelectorAll('.service-card'));
            const noResults = document.getElementById('noResults');
            const servicesGrid = document.getElementById('servicesGrid');
            const visibleCountEl = document.getElementById('visibleCount');
            const totalCount = serviceCards.length;

            let selectedCategory = 'all';

            // Категории
            categoryChips.forEach(chip => {
                chip.addEventListener('click', function() {
                    categoryChips.forEach(c => c.classList.remove('chip--active'));
                    this.classList.add('chip--active');
                    selectedCategory = this.dataset.category;
                    filterAndSortServices();
                });
            });

            function filterAndSortServices() {
                const searchTerm = searchInput.value.toLowerCase();
                const hideInactive = hideInactiveCheckbox.checked;
                const sortValue = sortSelect.value;
                const minPrice = parseFloat(minPriceInput.value) || 0;
                const maxPrice = parseFloat(maxPriceInput.value) || Infinity;
                const maxDuration = parseFloat(maxDurationInput.value) || Infinity;

                let visibleCards = serviceCards.filter(card => {
                    const name = card.dataset.name;
                    const status = card.dataset.status;
                    const price = parseFloat(card.dataset.price);
                    const duration = parseFloat(card.dataset.duration);
                    const category = card.dataset.category;

                    const matchesSearch = name.includes(searchTerm);
                    const matchesStatus = !hideInactive || status === 'active';
                    const matchesPrice = price >= minPrice && price <= maxPrice;
                    const matchesDuration = duration <= maxDuration;
                    const matchesCategory = selectedCategory === 'all' || category === selectedCategory;

                    return matchesSearch && matchesStatus && matchesPrice && matchesDuration && matchesCategory;
                });

                // Сортировка
                if (sortValue === 'price-asc') {
                    visibleCards.sort((a, b) => parseFloat(a.dataset.price) - parseFloat(b.dataset.price));
                } else if (sortValue === 'price-desc') {
                    visibleCards.sort((a, b) => parseFloat(b.dataset.price) - parseFloat(a.dataset.price));
                } else if (sortValue === 'duration-asc') {
                    visibleCards.sort((a, b) => parseFloat(a.dataset.duration) - parseFloat(b.dataset.duration));
                } else if (sortValue === 'duration-desc') {
                    visibleCards.sort((a, b) => parseFloat(b.dataset.duration) - parseFloat(a.dataset.duration));
                } else {
                    visibleCards.sort((a, b) => a.dataset.name.localeCompare(b.dataset.name));
                }

                // Скрываем все карточки
                serviceCards.forEach(card => card.style.display = 'none');

                // Показываем отфильтрованные и отсортированные
                visibleCards.forEach(card => {
                    card.style.display = '';
                    servicesGrid.appendChild(card);
                });

                // Обновляем счетчик
                visibleCountEl.textContent = visibleCards.length;

                // Показываем/скрываем empty state
                if (visibleCards.length === 0) {
                    servicesGrid.style.display = 'none';
                    noResults.style.display = 'flex';
                } else {
                    servicesGrid.style.display = 'grid';
                    noResults.style.display = 'none';
                }
            }

            // События
            searchInput.addEventListener('input', filterAndSortServices);
            hideInactiveCheckbox.addEventListener('change', filterAndSortServices);
            sortSelect.addEventListener('change', filterAndSortServices);
            applyButton.addEventListener('click', filterAndSortServices);
            
            // Применение по Enter в полях фильтров
            [minPriceInput, maxPriceInput, maxDurationInput].forEach(input => {
                input.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        filterAndSortServices();
                    }
                });
            });
        });
    </script>
}

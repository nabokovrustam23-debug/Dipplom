@page "/Account/Notifications"
@model BarbershopCrm.Web.Pages.Account.Notifications.IndexModel
@{
    ViewData["Title"] = "Мои уведомления";
    var filter = Model.Filter?.ToLowerInvariant() ?? "all";
    var sort = string.Equals(Model.Sort, "oldest", StringComparison.OrdinalIgnoreCase) ? "oldest" : "newest";
    var pageSize = BarbershopCrm.Web.Pages.Account.Notifications.IndexModel.DefaultPageSize;
    var rangeStart = Model.TotalCount == 0 ? 0 : ((Model.CurrentPage - 1) * pageSize) + 1;
    var rangeEnd = Math.Min(Model.TotalCount, Model.CurrentPage * pageSize);
}

<div class="notifications-page">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast toast--success" role="alert">
            <div class="toast__icon">✓</div>
            <div>@TempData["SuccessMessage"]</div>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast toast--error" role="alert">
            <div class="toast__icon">!</div>
            <div>@TempData["ErrorMessage"]</div>
        </div>
    }
    
    <header class="notifications-header">
        <div class="notifications-header__content">
            <h1>Мои уведомления</h1>
            <p class="muted">Подтверждения и отмены записей, напоминания, сервисные сообщения</p>
        </div>
        @if (Model.UnreadCount > 0)
        {
            <div class="notifications-header__badge">
                <span class="notifications-badge">@Model.UnreadCount</span>
                <form method="post" asp-page-handler="ReadAll" class="notifications-header__action">
                    <input type="hidden" name="Filter" value="@Model.Filter" />
                    <input type="hidden" name="Sort" value="@Model.Sort" />
                    <input type="hidden" name="page" value="@Model.CurrentPage" />
                    <button type="submit" class="btn btn--outline btn--small">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        Отметить все прочитанными
                    </button>
                </form>
            </div>
        }
    </header>

    <form method="get" class="toolbar" role="search">
        <div class="toolbar__group" role="tablist" aria-label="Фильтр">
            <a class="chip @(filter == "all" ? "chip--active" : "")"
               asp-route-filter="" asp-route-sort="@Model.Sort">
                Все
                @if (filter == "all")
                {
                    <span class="chip__count">@Model.TotalCount</span>
                }
            </a>
            <a class="chip @(filter == "unread" ? "chip--active" : "")"
               asp-route-filter="unread" asp-route-sort="@Model.Sort">
                Непрочитанные
                @if (Model.UnreadCount > 0)
                {
                    <span class="chip__count">@Model.UnreadCount</span>
                }
            </a>
            <a class="chip @(filter == "read" ? "chip--active" : "")"
               asp-route-filter="read" asp-route-sort="@Model.Sort">Прочитанные</a>
        </div>
        <div class="toolbar__divider"></div>
        <div class="toolbar__group">
            <label for="notif-sort" class="visually-hidden">Сортировка</label>
            <select id="notif-sort" name="sort" class="input" onchange="this.form.submit()">
                <option value="newest" selected="@(sort == "newest")">Сначала новые</option>
                <option value="oldest" selected="@(sort == "oldest")">Сначала старые</option>
            </select>
            <input type="hidden" name="filter" value="@Model.Filter" />
            <noscript><button class="btn btn--outline btn--small" type="submit">Применить</button></noscript>
        </div>
    </form>

    @if (!Model.Items.Any())
    {
        <div class="notifications-empty">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
            </svg>
            <p>Уведомлений нет</p>
            <p class="muted">
                @if (filter == "unread")
                {
                    <text>Все уведомления прочитаны</text>
                }
                else if (filter == "read")
                {
                    <text>Прочитанных уведомлений пока нет</text>
                }
                else
                {
                    <text>Уведомления появятся здесь</text>
                }
            </p>
        </div>
    }
    else
    {
        <div class="notifications-list">
            @foreach (var n in Model.Items)
            {
                var unread = n.ReadAt is null;
                <article class="notification-card @(unread ? "notification-card--unread" : "")">
                    <div class="notification-card__indicator"></div>
                    <div class="notification-card__content">
                        <div class="notification-card__header">
                            <h3 class="notification-card__subject">@n.Subject</h3>
                            <time class="notification-card__date" datetime="@n.CreatedAt.ToString("o")">
                                @n.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </time>
                        </div>
                        <div class="notification-card__body">@n.Body</div>
                        @if (unread)
                        {
                            <form method="post" asp-page-handler="Read" asp-route-id="@n.NotificationId" class="notification-card__actions">
                                <input type="hidden" name="Filter" value="@Model.Filter" />
                                <input type="hidden" name="Sort" value="@Model.Sort" />
                                <input type="hidden" name="page" value="@Model.CurrentPage" />
                                <button type="submit" class="btn btn--ghost btn--small">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                    Прочитано
                                </button>
                            </form>
                        }
                    </div>
                </article>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="pagination" aria-label="Постраничная навигация">
                <div class="pagination__info">
                    <span class="muted">@rangeStart–@rangeEnd из @Model.TotalCount</span>
                </div>
                <div class="pagination__controls">
                    @if (Model.CurrentPage > 1)
                    {
                        <a class="btn btn--outline btn--small"
                           asp-route-filter="@Model.Filter"
                           asp-route-sort="@Model.Sort"
                           asp-route-page="@(Model.CurrentPage - 1)">
                            ← Назад
                        </a>
                    }
                    <span class="pagination__current">Страница @Model.CurrentPage из @Model.TotalPages</span>
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a class="btn btn--outline btn--small"
                           asp-route-filter="@Model.Filter"
                           asp-route-sort="@Model.Sort"
                           asp-route-page="@(Model.CurrentPage + 1)">
                            Дальше →
                        </a>
                    }
                </div>
            </nav>
        }
    }
</div>

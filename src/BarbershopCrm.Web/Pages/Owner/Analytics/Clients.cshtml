@page "/Owner/Analytics/Clients"
@model BarbershopCrm.Web.Pages.Owner.Analytics.ClientsModel
@{
    ViewData["Title"] = "Аналитика клиентов";
    ViewData["ManagementTab"] = "analytics";
}

<partial name="_ManagementTabs" />

<section class="card">
    <div class="card__header">
        <h1>Аналитика клиентов — @(Model.Snapshot?.BranchName ?? "вся сеть")</h1>
        <div class="card__header-actions">
            <a asp-page="/Owner/Analytics/Index"
               asp-route-from="@Model.FromValue.ToString("yyyy-MM-dd")"
               asp-route-to="@Model.ToValue.ToString("yyyy-MM-dd")"
               asp-route-branchid="@Model.BranchId"
               class="btn btn--outline">← Общая аналитика</a>
        </div>
    </div>

    <form method="get" class="form-row" id="clientsFilterForm">
        <div class="form-group">
            <label for="BranchId">Филиал</label>
            <select id="BranchId" name="BranchId" class="input">
                <option value="">Вся сеть</option>
                @foreach (var b in Model.BranchOptions)
                {
                    <option value="@b.Value" selected="@(Model.BranchId?.ToString() == b.Value)">@b.Text</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label for="From">С</label>
            <input id="From" name="From" type="date" class="input" value="@Model.FromValue.ToString("yyyy-MM-dd")" />
        </div>
        <div class="form-group">
            <label for="To">По</label>
            <input id="To" name="To" type="date" class="input" value="@Model.ToValue.ToString("yyyy-MM-dd")" />
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn--primary">Применить</button>
            <a asp-page="/Owner/Analytics/Clients" class="btn btn--outline">Сбросить</a>
        </div>
    </form>
</section>

@if (Model.Snapshot is not null)
{
    <section class="card export-card">
        <div class="export-card__body">
            <div class="export-card__icon" aria-hidden="true"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></div>
            <div class="export-card__text">
                <h2 class="export-card__title">Экспорт клиентов в CSV</h2>
                <p class="export-card__desc">
                    Полный список клиентов с аналитикой
                    @(Model.Snapshot.BranchName is { Length: > 0 } b ? $"филиала «{b}»" : "по всей сети")
                    за период
                    <strong>@Model.FromValue.ToString("dd.MM.yyyy") — @Model.ToValue.ToString("dd.MM.yyyy")</strong>:
                    визиты, выручка, ABC-категория, уровень лояльности.
                </p>
            </div>
            <a asp-page="/Owner/Analytics/Clients" asp-page-handler="Export"
               asp-route-from="@Model.FromValue.ToString("yyyy-MM-dd")"
               asp-route-to="@Model.ToValue.ToString("yyyy-MM-dd")"
               asp-route-branchid="@Model.BranchId"
               class="btn btn--primary export-card__btn">Скачать .csv</a>
        </div>
    </section>

    <!-- Сводка по сегментации -->
    <section class="card">
        <div class="card__header">
            <h2>Сводка по клиентам</h2>
        </div>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-card__label">Всего клиентов</div>
                <div class="stat-card__value">@Model.Snapshot.TotalClients</div>
            </div>
        </div>
    </section>

    <!-- ABC-анализ -->
    <section class="card">
        <div class="card__header">
            <h2>ABC-анализ клиентов</h2>
            <p class="muted">Распределение клиентов по вкладу в выручку</p>
        </div>
        <div class="abc-grid">
            <div class="abc-card abc-card--a">
                <div class="abc-card__header">
                    <span class="abc-card__badge">A</span>
                    <span class="abc-card__title">Топ-клиенты</span>
                </div>
                <div class="abc-card__stats">
                    <div class="abc-stat">
                        <span class="abc-stat__label">Клиентов</span>
                        <span class="abc-stat__value">@Model.Snapshot.AbcDistribution.CategoryACount</span>
                    </div>
                    <div class="abc-stat">
                        <span class="abc-stat__label">Выручка</span>
                        <span class="abc-stat__value">@Model.Snapshot.AbcDistribution.CategoryARevenue.ToString("N0") ₽</span>
                    </div>
                    <div class="abc-stat abc-stat--highlight">
                        <span class="abc-stat__label">Доля выручки</span>
                        <span class="abc-stat__value">@Model.Snapshot.AbcDistribution.CategoryARevenuePercent.ToString("0.0")%</span>
                    </div>
                </div>
            </div>

            <div class="abc-card abc-card--b">
                <div class="abc-card__header">
                    <span class="abc-card__badge">B</span>
                    <span class="abc-card__title">Средние клиенты</span>
                </div>
                <div class="abc-card__stats">
                    <div class="abc-stat">
                        <span class="abc-stat__label">Клиентов</span>
                        <span class="abc-stat__value">@Model.Snapshot.AbcDistribution.CategoryBCount</span>
                    </div>
                    <div class="abc-stat">
                        <span class="abc-stat__label">Выручка</span>
                        <span class="abc-stat__value">@Model.Snapshot.AbcDistribution.CategoryBRevenue.ToString("N0") ₽</span>
                    </div>
                    <div class="abc-stat abc-stat--highlight">
                        <span class="abc-stat__label">Доля выручки</span>
                        <span class="abc-stat__value">@Model.Snapshot.AbcDistribution.CategoryBRevenuePercent.ToString("0.0")%</span>
                    </div>
                </div>
            </div>

            <div class="abc-card abc-card--c">
                <div class="abc-card__header">
                    <span class="abc-card__badge">C</span>
                    <span class="abc-card__title">Остальные клиенты</span>
                </div>
                <div class="abc-card__stats">
                    <div class="abc-stat">
                        <span class="abc-stat__label">Клиентов</span>
                        <span class="abc-stat__value">@Model.Snapshot.AbcDistribution.CategoryCCount</span>
                    </div>
                    <div class="abc-stat">
                        <span class="abc-stat__label">Выручка</span>
                        <span class="abc-stat__value">@Model.Snapshot.AbcDistribution.CategoryCRevenue.ToString("N0") ₽</span>
                    </div>
                    <div class="abc-stat abc-stat--highlight">
                        <span class="abc-stat__label">Доля выручки</span>
                        <span class="abc-stat__value">@Model.Snapshot.AbcDistribution.CategoryCRevenuePercent.ToString("0.0")%</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Распределение по уровням -->
    <section class="card">
        <div class="card__header">
            <h2>Распределение по уровням лояльности</h2>
            <p class="muted">Сегментация клиентов по количеству визитов</p>
        </div>
        <div class="tier-grid">
            <div class="tier-card tier-card--new">
                <div class="tier-card__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div>
                <div class="tier-card__title">Новые</div>
                <div class="tier-card__count">@Model.Snapshot.TierDistribution.NewCount</div>
                <div class="tier-card__desc">1 визит</div>
            </div>
            <div class="tier-card tier-card--regular">
                <div class="tier-card__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
                <div class="tier-card__title">Постоянные</div>
                <div class="tier-card__count">@Model.Snapshot.TierDistribution.RegularCount</div>
                <div class="tier-card__desc">2-5 визитов</div>
            </div>
            <div class="tier-card tier-card--loyal">
                <div class="tier-card__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
                <div class="tier-card__title">Лояльные</div>
                <div class="tier-card__count">@Model.Snapshot.TierDistribution.LoyalCount</div>
                <div class="tier-card__desc">6-10 визитов</div>
            </div>
            <div class="tier-card tier-card--vip">
                <div class="tier-card__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 19l2-14 4 6 4-6 4 6 4-6 2 14H2z"/><path d="M7 19l2-6 3 2 3-2 2 6"/></svg></div>
                <div class="tier-card__title">VIP</div>
                <div class="tier-card__count">@Model.Snapshot.TierDistribution.VipCount</div>
                <div class="tier-card__desc">11+ визитов</div>
            </div>
        </div>
    </section>

    <!-- Топ-20 клиентов -->
    <section class="card">
        <div class="card__header">
            <h2>Топ-20 клиентов по выручке</h2>
        </div>
        @if (Model.Snapshot.TopClients.Any())
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ABC</th>
                            <th>Уровень</th>
                            <th>Клиент</th>
                            <th>Контакты</th>
                            <th class="text-right">Визитов</th>
                            <th class="text-right">Выручка</th>
                            <th class="text-right">Средний чек</th>
                            <th>Последний визит</th>
                            <th>Предпочтения</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var client in Model.Snapshot.TopClients)
                        {
                            <tr>
                                <td>
                                    <span class="badge badge--@(client.AbcCategory.ToString().ToLower())">
                                        @client.AbcCategory
                                    </span>
                                </td>
                                <td>
                                    <span class="badge badge--tier-@(client.Tier.ToString().ToLower())">
                                        @switch (client.Tier)
                                        {
                                            case BarbershopCrm.Infrastructure.Analytics.ClientTier.New:
                                                @:Новый
                                                break;
                                            case BarbershopCrm.Infrastructure.Analytics.ClientTier.Regular:
                                                @:Постоянный
                                                break;
                                            case BarbershopCrm.Infrastructure.Analytics.ClientTier.Loyal:
                                                @:Лояльный
                                                break;
                                            case BarbershopCrm.Infrastructure.Analytics.ClientTier.VIP:
                                                @:VIP
                                                break;
                                        }
                                    </span>
                                </td>
                                <td><strong>@client.ClientName</strong></td>
                                <td class="text-muted small">
                                    @if (!string.IsNullOrEmpty(client.Phone))
                                    {
                                        <div><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg> @client.Phone</div>
                                    }
                                    @if (!string.IsNullOrEmpty(client.Email))
                                    {
                                        <div><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg> @client.Email</div>
                                    }
                                </td>
                                <td class="text-right">@client.TotalVisits</td>
                                <td class="text-right"><strong>@client.TotalRevenue.ToString("N0") ₽</strong></td>
                                <td class="text-right">@client.AverageTicket.ToString("N0") ₽</td>
                                <td>
                                    <div>@client.LastVisitDate.ToString("dd.MM.yyyy")</div>
                                    <div class="text-muted small">@client.DaysSinceLastVisit дн. назад</div>
                                </td>
                                <td class="text-muted small">
                                    @if (!string.IsNullOrEmpty(client.PreferredMaster))
                                    {
                                        <div><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> @client.PreferredMaster</div>
                                    }
                                    @if (!string.IsNullOrEmpty(client.PreferredService))
                                    {
                                        <div><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px"><path d="M20.94 11h-2.08A5.98 5.98 0 0 0 14 6.14V4h-4v2.14A5.98 5.98 0 0 0 5.14 11H3.06a.5.5 0 0 0-.5.54A9 9 0 0 0 12 20a9 9 0 0 0 9.38-8.46.5.5 0 0 0-.44-.54z"/><circle cx="12" cy="15" r="2"/><line x1="4" y1="14" x2="3" y2="14"/><line x1="21" y1="14" x2="20" y2="14"/></svg> @client.PreferredService</div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="muted">Нет данных о клиентах за выбранный период.</p>
        }
    </section>
}


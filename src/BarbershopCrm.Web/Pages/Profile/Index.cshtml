@page
@model BarbershopCrm.Web.Pages.Profile.IndexModel
@{
    ViewData["Title"] = "Личный кабинет";
}

<section class="profile-section">
    <!-- Profile Header with Avatar -->
    <div class="profile-header">
        <div class="profile-avatar">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
            </svg>
        </div>
        
        <div class="profile-header__info">
            <h1 class="profile-header__name">@Model.Current!.FullName</h1>
            <div class="profile-header__meta">
                <span class="profile-header__role">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                    @Model.RoleLabel
                </span>
                @if (Model.Current.BranchId is { } branchId)
                {
                    <span class="profile-header__branch">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                            <circle cx="12" cy="10" r="3"></circle>
                        </svg>
                        Филиал #@branchId
                    </span>
                }
            </div>
        </div>

        <div class="profile-header__actions">
            <a asp-page="/Profile/Edit" class="btn btn--outline">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
                Редактировать
            </a>
        </div>
    </div>

    <!-- Contact Information Card -->
    <div class="profile-grid">
        <div class="card profile-info-card">
            <h2 class="profile-card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
                Контактная информация
            </h2>
            <dl class="profile-details">
                <div class="profile-details__item">
                    <dt>Телефон</dt>
                    <dd>
                        <span class="profile-details__value">@Model.Current.Phone</span>
                    </dd>
                </div>

                <div class="profile-details__item">
                    <dt>Email</dt>
                    <dd>
                        <span class="profile-details__value">@Model.Current.Email</span>
                        @if (Model.Current.IsEmailConfirmed)
                        {
                            <span class="badge badge--ok">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                                подтверждён
                            </span>
                        }
                        else
                        {
                            <span class="badge badge--warn">не подтверждён</span>
                            <a asp-page="/Account/ResendConfirmationEmail"
                               asp-route-email="@Model.Current.Email"
                               class="btn-link btn-link--small">Отправить ссылку</a>
                        }
                    </dd>
                </div>

                <div class="profile-details__item">
                    <dt>Логин</dt>
                    <dd>
                        <span class="profile-details__value">@Model.Current.Login</span>
                    </dd>
                </div>
            </dl>
        </div>

        @if (Model.LoyaltyInfo != null)
        {
            <!-- Loyalty Program Card -->
            <div class="card loyalty-card">
                <div class="loyalty-card__header">
                    <h2 class="profile-card-title">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                        </svg>
                        Программа лояльности
                    </h2>
                    @if (Model.LoyaltyInfo.CurrentTier.DiscountPercent > 0)
                    {
                        <div class="loyalty-card__discount">
                            <span class="loyalty-card__discount-value">@Model.LoyaltyInfo.CurrentTier.DiscountPercent%</span>
                            <span class="loyalty-card__discount-label">скидка</span>
                        </div>
                    }
                </div>

                <div class="loyalty-tier">
                    <div class="loyalty-tier__current">
                        <span class="loyalty-tier__label">Текущий статус</span>
                        <span class="loyalty-tier__name">@Model.LoyaltyInfo.CurrentTier.DisplayName</span>
                    </div>
                    <div class="loyalty-tier__visits">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                        </svg>
                        <span>@Model.LoyaltyInfo.CompletedVisits визитов завершено</span>
                    </div>
                </div>

                <p class="loyalty-card__motivation">@Model.LoyaltyInfo.MotivationText</p>

                <a asp-page="/Account/Loyalty/Index" class="btn btn--primary" style="margin-top: var(--space-4); width: 100%;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                    </svg>
                    Перейти в программу лояльности
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                </a>
            </div>
        }
    </div>

    <!-- Actions -->
    <div class="profile-actions">
        <form method="post" asp-page="/Account/Logout" class="profile-actions__logout">
            <button class="btn btn--outline btn--danger-outline" type="submit">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
                Выйти из аккаунта
            </button>
        </form>
    </div>
</section>

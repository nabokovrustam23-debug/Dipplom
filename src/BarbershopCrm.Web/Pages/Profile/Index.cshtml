@page
@model BarbershopCrm.Web.Pages.Profile.IndexModel
@{
    ViewData["Title"] = "Личный кабинет";
}

<div class="profile-section-hub">
    <!-- Hero Card -->
    <div class="profile-hero-card card">
        <div class="profile-hero-avatar">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
            </svg>
        </div>
        <div class="profile-hero-body">
            <h1 class="profile-hero-name">@Model.Current!.FullName</h1>
            <div class="profile-hero-meta">
                <span class="badge">@Model.RoleLabel</span>
                @if (Model.Current.BranchId is { } branchId)
                {
                    <span class="profile-hero-branch">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                            <circle cx="12" cy="10" r="3" />
                        </svg>
                        Филиал #@branchId
                    </span>
                }
            </div>
        </div>
        <div class="profile-hero-actions-container">
            <a asp-page="/Profile/Edit" class="btn btn--outline">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                </svg>
                Редактировать
            </a>
        </div>
    </div>

    <!-- Info Grid -->
    <div class="profile-grid">
        <div class="card profile-info-card">
            <h2 class="profile-card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                </svg>
                Контактная информация
            </h2>
            <dl class="profile-details">
                <div class="profile-details__item">
                    <dt>Телефон</dt>
                    <dd><span class="profile-details__value">@Model.Current.Phone</span></dd>
                </div>
                <div class="profile-details__item">
                    <dt>Email</dt>
                    <dd><span class="profile-details__value">@Model.Current.Email</span></dd>
                </div>
                <div class="profile-details__item">
                    <dt>Логин</dt>
                    <dd><span class="profile-details__value">@Model.Current.Login</span></dd>
                </div>
            </dl>
        </div>

        @if (Model.LoyaltyInfo != null)
        {
            <div class="card loyalty-card">
                <div class="loyalty-card-widget-top">
                    <h2 class="profile-card-title">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                        </svg>
                        Программа лояльности
                    </h2>
                    @if (Model.LoyaltyInfo.CurrentTier.DiscountPercent > 0)
                    {
                        <div class="loyalty-card-discount-badge">
                            <span class="loyalty-card-discount-value">-@Model.LoyaltyInfo.CurrentTier.DiscountPercent%</span>
                            <span class="loyalty-card-discount-label">скидка</span>
                        </div>
                    }
                </div>

                <div class="loyalty-tier">
                    <div class="loyalty-tier__current">
                        <span class="loyalty-tier__label">Текущий статус</span>
                        <span class="loyalty-tier__name">@Model.LoyaltyInfo.CurrentTier.DisplayName</span>
                    </div>
                    <div class="loyalty-tier__visits">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                        </svg>
                        <span>@Model.LoyaltyInfo.CompletedVisits визитов завершено</span>
                    </div>
                </div>

                @if (Model.LoyaltyInfo.NextTier is { } next)
                {
                    <div class="loyalty-progress">
                        <div class="loyalty-progress__header">
                            <span class="loyalty-progress__label">Прогресс</span>
                            <span class="loyalty-progress__target">@Model.LoyaltyInfo.VisitsToNextTier визитов до @next.DisplayName</span>
                        </div>
                        <div class="loyalty-progress__bar">
                            @{
                                var total = Model.LoyaltyInfo.CompletedVisits + Model.LoyaltyInfo.VisitsToNextTier;
                                var pct = total > 0 ? (int)((double)Model.LoyaltyInfo.CompletedVisits / total * 100) : 0;
                            }
                            <div class="loyalty-progress__fill" style="width:@(pct)%"></div>
                        </div>
                        <p class="loyalty-progress__text">
                            <strong>@Model.LoyaltyInfo.CompletedVisits</strong> из <strong>@total</strong> визитов
                        </p>
                    </div>
                }

                <p class="loyalty-card__motivation">@Model.LoyaltyInfo.MotivationText</p>

                <a asp-page="/Account/Loyalty/Index" class="btn btn--primary btn--block">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                    Перейти в программу лояльности
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                </a>
            </div>
        }
    </div>

    <!-- Password Change -->
    <div class="card profile-info-card">
        <h2 class="profile-card-title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            Сменить пароль
        </h2>
        <form method="post" asp-page-handler="ChangePassword">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <dl class="profile-details">
                <div class="profile-details__item">
                    <dt><label asp-for="PasswordInput.CurrentPassword"></label></dt>
                    <dd>
                        <input asp-for="PasswordInput.CurrentPassword" class="input" />
                        <span asp-validation-for="PasswordInput.CurrentPassword" class="text-danger"></span>
                    </dd>
                </div>
                <div class="profile-details__item">
                    <dt><label asp-for="PasswordInput.NewPassword"></label></dt>
                    <dd>
                        <input asp-for="PasswordInput.NewPassword" class="input" />
                        <span asp-validation-for="PasswordInput.NewPassword" class="text-danger"></span>
                    </dd>
                </div>
                <div class="profile-details__item">
                    <dt><label asp-for="PasswordInput.NewPasswordRepeat"></label></dt>
                    <dd>
                        <input asp-for="PasswordInput.NewPasswordRepeat" class="input" />
                        <span asp-validation-for="PasswordInput.NewPasswordRepeat" class="text-danger"></span>
                    </dd>
                </div>
            </dl>
            <button type="submit" class="btn btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                    <polyline points="17 21 17 13 7 13 7 21" />
                    <polyline points="7 3 7 8 15 8" />
                </svg>
                Сохранить пароль
            </button>
        </form>
    </div>

    <!-- Exit Zone -->
    <div class="profile-actions-exit-zone">
        <form method="post" asp-page="/Account/Logout">
            <button class="btn btn--outline btn--danger-outline" type="submit">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                Выйти из аккаунта
            </button>
        </form>
    </div>
</div>

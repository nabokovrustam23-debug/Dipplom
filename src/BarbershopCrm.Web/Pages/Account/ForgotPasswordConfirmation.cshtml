@page
@model BarbershopCrm.Web.Pages.Account.ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Письмо отправлено";
}

<section class="auth-shell">
    <div class="auth-card card">
        <h1>Проверьте почту</h1>
        <p class="muted">
            Если такой email зарегистрирован у нас, мы отправили на него письмо со ссылкой
            для смены пароля. Ссылка действительна 1 час.
        </p>
        <div class="auth-actions">
            <a asp-page="/Account/Login" class="btn btn--primary">К входу</a>
        </div>
    </div>
</section>

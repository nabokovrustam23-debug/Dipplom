@page
@model BarbershopCrm.Web.Pages.Owner.Services.CreateModel
@{
    ViewData["Title"] = "Создание услуги";
    ViewData["ManagementTab"] = "services";
}

<partial name="_ManagementTabs" />

<section class="service-form-section">
    <div class="service-form-header">
        <div>
            <h2>Создание новой услуги</h2>
            <p class="muted">Добавьте услугу в прайс-лист</p>
        </div>
        <a asp-page="Index" class="btn btn--ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Назад к списку
        </a>
    </div>

    <form method="post" enctype="multipart/form-data" class="service-form" data-busy>
        <div asp-validation-summary="ModelOnly" class="alert alert--error"></div>

        <!-- Основная информация -->
        <div class="card">
            <div class="service-form-section-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                    <line x1="7" y1="7" x2="7.01" y2="7"></line>
                </svg>
                <h3>Основная информация</h3>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Input.Name">
                        Название услуги
                        <span class="required-mark">*</span>
                    </label>
                    <input asp-for="Input.Name" 
                           class="input" 
                           placeholder="Например: Мужская стрижка, Окрашивание" 
                           required 
                           autocomplete="off" />
                    <span asp-validation-for="Input.Name" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Description">Описание</label>
                    <textarea asp-for="Input.Description" 
                              class="input" 
                              rows="3" 
                              placeholder="Краткое описание услуги для клиентов"></textarea>
                    <span asp-validation-for="Input.Description" class="field-error"></span>
                    <small class="form-hint">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="M12 16v-4"></path>
                            <path d="M12 8h.01"></path>
                        </svg>
                        Описание будет отображаться на сайте при выборе услуги
                    </small>
                </div>
            </div>
        </div>

        <!-- Параметры услуги -->
        <div class="card">
            <div class="service-form-section-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                <h3>Параметры услуги</h3>
            </div>

            <div class="form-grid">
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.DurationMinutes">
                            Длительность (минут)
                            <span class="required-mark">*</span>
                        </label>
                        <div class="input-with-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                            <input asp-for="Input.DurationMinutes" 
                                   type="number" 
                                   class="input input--with-icon" 
                                   min="5" 
                                   max="480" 
                                   required />
                        </div>
                        <span asp-validation-for="Input.DurationMinutes" class="field-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.Price">
                            Цена (₽)
                            <span class="required-mark">*</span>
                        </label>
                        <input asp-for="Input.Price"
                               type="number"
                               step="0.01"
                               class="input"
                               min="0.01"
                               required />
                        <span asp-validation-for="Input.Price" class="field-error"></span>
                    </div>
                </div>
                <small class="form-hint">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M12 16v-4"></path>
                        <path d="M12 8h.01"></path>
                    </svg>
                    Длительность влияет на расписание мастеров. Цена отображается в прайс-листе.
                </small>
            </div>
        </div>

        <!-- Фото -->
        <div class="card">
            <div class="service-form-section-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                    <polyline points="21 15 16 10 5 21"></polyline>
                </svg>
                <h3>Фотография услуги</h3>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Input.ImageFile">Выберите фото</label>
                    <input asp-for="Input.ImageFile" 
                           type="file" 
                           accept="image/*" 
                           class="input input--file" 
                           id="serviceImageInput" />
                    <span asp-validation-for="Input.ImageFile" class="field-error"></span>
                    <small class="form-hint">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="M12 16v-4"></path>
                            <path d="M12 8h.01"></path>
                        </svg>
                        Рекомендуемый размер: 800×600 пикселей. Максимум 5 МБ. Форматы: JPG, PNG, WebP.
                    </small>
                </div>

                <div id="serviceImagePreview" class="image-preview" style="display: none;">
                    <img id="servicePreviewImg" src="" alt="Предпросмотр" />
                    <button type="button" class="image-preview__remove" onclick="removeServiceImage()">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Статус -->
        <div class="card">
            <div class="form-grid">
                <div class="form-group">
                    <label class="checkbox-inline">
                        <input asp-for="Input.IsActive" type="checkbox" />
                        <span class="checkbox-label-text">
                            <strong>Услуга активна</strong>
                            <small>Активные услуги отображаются на сайте и доступны для записи</small>
                        </span>
                    </label>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                Создать услугу
            </button>
            <a asp-page="Index" class="btn btn--outline">Отмена</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('serviceImageInput').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('servicePreviewImg').src = e.target.result;
                    document.getElementById('serviceImagePreview').style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });

        function removeServiceImage() {
            document.getElementById('serviceImageInput').value = '';
            document.getElementById('serviceImagePreview').style.display = 'none';
        }
    </script>
}

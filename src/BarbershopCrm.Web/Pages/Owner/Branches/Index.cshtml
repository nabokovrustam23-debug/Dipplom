@page
@model BarbershopCrm.Web.Pages.Owner.Branches.IndexModel
@{
    ViewData["Title"] = "Управление · Филиалы";
    ViewData["ManagementTab"] = "branches";
}

<partial name="_ManagementTabs" />

<section class="branches-management">
    <div class="branches-header">
        <div class="branches-header__content">
            <h2>Филиалы</h2>
            <p class="branches-header__subtitle">Управление филиалами сети</p>
        </div>
        <div class="branches-header__stats">
            <div class="stat-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                </svg>
                <div class="stat-badge__content">
                    <div class="stat-badge__value">@Model.Branches.Count</div>
                    <div class="stat-badge__label">Всего</div>
                </div>
            </div>
            <div class="stat-badge stat-badge--success">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <div class="stat-badge__content">
                    <div class="stat-badge__value">@Model.Branches.Count(b => b.IsActive)</div>
                    <div class="stat-badge__label">Активных</div>
                </div>
            </div>
        </div>
    </div>

    <div class="branches-toolbar">
        <div class="branches-search">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
            </svg>
            <input type="text" 
                   id="branchSearch" 
                   class="branches-search__input" 
                   placeholder="Поиск по названию или адресу..." 
                   autocomplete="off" />
        </div>
        
        <div class="branches-filters">
            <label class="filter-checkbox">
                <input type="checkbox" id="hideInactive" />
                <span>Скрыть неактивные</span>
            </label>
        </div>

        <a asp-page="Create" class="btn btn--primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Создать филиал
        </a>
    </div>

    @if (Model.Branches.Count == 0)
    {
        <div class="empty-state">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <h3>Нет филиалов</h3>
            <p>Создайте первый филиал для начала работы</p>
            <a asp-page="Create" class="btn btn--primary">Создать филиал</a>
        </div>
    }
    else
    {
        <div class="branches-grid" id="branchesGrid">
            @foreach (var b in Model.Branches)
            {
                <div class="branch-card @(b.IsActive ? "" : "branch-card--inactive")" 
                     data-name="@b.Name.ToLower()" 
                     data-address="@b.Address.ToLower()"
                     data-status="@(b.IsActive ? "active" : "inactive")">
                    <div class="branch-card__image">
                        @if (!string.IsNullOrEmpty(b.ImageUrl))
                        {
                            <img src="@b.ImageUrl" alt="@b.Name" loading="lazy" />
                        }
                        else
                        {
                            <div class="branch-card__image-placeholder">
                                <img src="~/images/branch-placeholder.svg" alt="" style="width:48px;height:48px;" />
                            </div>
                        }
                        <div class="branch-card__status">
                            @if (b.IsActive)
                            {
                                <span class="badge badge--ok">Активен</span>
                            }
                            else
                            {
                                <span class="badge badge--warn">Закрыт</span>
                            }
                        </div>
                    </div>

                    <div class="branch-card__content">
                        <h3 class="branch-card__name">@b.Name</h3>
                        
                        <div class="branch-card__info">
                            <div class="branch-card__info-item">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                    <circle cx="12" cy="10" r="3"></circle>
                                </svg>
                                <span>@b.Address</span>
                            </div>

                            <div class="branch-card__info-item">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <polyline points="12 6 12 12 16 14"></polyline>
                                </svg>
                                <span class="tnum">@b.OpeningTime.ToString("HH:mm") – @b.ClosingTime.ToString("HH:mm")</span>
                            </div>

                            @if (!string.IsNullOrEmpty(b.Phone))
                            {
                                <div class="branch-card__info-item">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                                    </svg>
                                    <span class="tnum">@b.Phone</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="branch-card__actions">
                        <a asp-page="Edit" asp-route-id="@b.BranchId" class="btn btn--outline btn--sm">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                            </svg>
                            Изменить
                        </a>
                        @if (b.IsActive)
                        {
                            <a asp-page="Delete" asp-route-id="@b.BranchId" class="btn btn--outline btn--sm btn--danger-outline">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="3 6 5 6 21 6"></polyline>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                </svg>
                                Закрыть
                            </a>
                        }
                    </div>
                </div>
            }
        </div>

        <div id="noResults" class="empty-state" style="display: none;">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
            </svg>
            <h3>Ничего не найдено</h3>
            <p>Попробуйте изменить параметры поиска</p>
        </div>
    }
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('branchSearch');
            const hideInactiveCheckbox = document.getElementById('hideInactive');
            const branchCards = document.querySelectorAll('.branch-card');
            const noResults = document.getElementById('noResults');
            const branchesGrid = document.getElementById('branchesGrid');

            function filterBranches() {
                const searchTerm = searchInput.value.toLowerCase();
                const hideInactive = hideInactiveCheckbox.checked;
                let visibleCount = 0;

                branchCards.forEach(card => {
                    const name = card.dataset.name;
                    const address = card.dataset.address;
                    const status = card.dataset.status;

                    const matchesSearch = name.includes(searchTerm) || address.includes(searchTerm);
                    const matchesStatus = !hideInactive || status === 'active';

                    if (matchesSearch && matchesStatus) {
                        card.style.display = '';
                        visibleCount++;
                    } else {
                        card.style.display = 'none';
                    }
                });

                if (visibleCount === 0) {
                    branchesGrid.style.display = 'none';
                    noResults.style.display = 'flex';
                } else {
                    branchesGrid.style.display = 'grid';
                    noResults.style.display = 'none';
                }
            }

            searchInput.addEventListener('input', filterBranches);
            hideInactiveCheckbox.addEventListener('change', filterBranches);
        });
    </script>
}


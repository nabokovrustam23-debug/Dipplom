@page "/Lead"
@model BarbershopCrm.Web.Pages.Lead.IndexModel
@{
    ViewData["Title"] = "Оставить заявку — Тихого Часа";
}

<div class="request-page-layout animate-fade-in">
    <div class="request-page-container">
        
        <div class="request-page-info-panel">
            <div class="request-badge-pill">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
                <span>Обратная связь</span>
            </div>
            
            <h1 class="request-page-title">Перезвоним и подберём идеальное время</h1>
            <p class="request-page-description">
                Оставьте ваши контакты — старший администратор свяжется с вами в течение 15 минут, проконсультирует по услугам бренда и забронирует удобное кресло.
            </p>
            
            <div class="request-features-stack">
                <div class="request-feature-node">
                    <div class="request-feature-node__icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </div>
                    <div class="request-feature-node__text">
                        <strong>Мгновенный отклик</strong>
                        <span>Связь с администратором за 15 минут</span>
                    </div>
                </div>
                
                <div class="request-feature-node">
                    <div class="request-feature-node__icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </div>
                    <div class="request-feature-node__text">
                        <strong>Гибкое планирование</strong>
                        <span>Помощь в подборе слота к топ-мастерам</span>
                    </div>
                </div>
                
                <div class="request-feature-node">
                    <div class="request-feature-node__icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </div>
                    <div class="request-feature-node__text">
                        <strong>Персональный подход</strong>
                        <span>Учтём любые пожелания по стрижке и уходу</span>
                    </div>
                </div>
            </div>
            
            <div class="request-alt-routing-box">
                <p>Предпочитаете полностью самостоятельную запись?</p>
                <a asp-page="/BookingFlow/New" class="btn btn--outline btn--with-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line>
                    </svg>
                    <span>Выбрать время онлайн</span>
                </a>
            </div>
        </div>
        
        <div class="request-page-form-panel">
            <div class="request-widget-card">
                <div class="request-widget-card__header">
                    <h2>Оставить заявку</h2>
                    <p class="muted">Заполните анкету, чтобы менеджер подготовил свободные окна</p>
                </div>
                
                <div asp-validation-summary="All" class="alert alert--error alert--modern" style="margin-bottom: 1.5rem;"></div>
                
                <form method="post" data-busy class="auth-form">
                    <div class="request-widget-card__body">
                        
                        <div class="form-group" style="margin-bottom: 1.25rem;">
                            <label asp-for="Input.Name" class="form-label-dark">Ваше имя</label>
                            <div class="input-with-icon-layout">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="search-icon-inside">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>
                                </svg>
                                <input asp-for="Input.Name" class="input input--hub" style="padding-left: 36px;" autocomplete="name" placeholder="Александр Иванов" required />
                            </div>
                            <span asp-validation-for="Input.Name" class="field-error"></span>
                        </div>
                        
                        <div class="form-group" style="margin-bottom: 1.25rem;">
                            <label asp-for="Input.Phone" class="form-label-dark">Номер телефона связи</label>
                            <div class="input-with-icon-layout">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="search-icon-inside">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                                </svg>
                                <input asp-for="Input.Phone" class="input input--hub tnum" style="padding-left: 36px;" autocomplete="tel" placeholder="+7 (900) 000-00-00" required />
                            </div>
                            <span asp-validation-for="Input.Phone" class="field-error"></span>
                        </div>
                        
                        <div class="form-group" style="margin-bottom: 1.25rem;">
                            <label asp-for="Input.PreferredBranchId" class="form-label-dark">Предпочитаемый филиал сети</label>
                            <div class="input-with-icon-layout">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="search-icon-inside">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle>
                                </svg>
                                <select asp-for="Input.PreferredBranchId" asp-items="Model.Branches" class="input input--hub text-color-main" style="padding-left: 36px;" required>
                                    <option value="">— выберите филиал —</option>
                                </select>
                            </div>
                            <span asp-validation-for="Input.PreferredBranchId" class="field-error"></span>
                        </div>
                        
                        <div class="form-group" style="margin-bottom: 1.5rem;">
                            <label asp-for="Input.Comment" class="form-label-dark">Особые пожелания или желаемое время сеанса</label>
                            <div class="input-with-icon-layout">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="search-icon-inside" style="top: 18px; transform: none;">
                                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                                </svg>
                                <textarea asp-for="Input.Comment" class="input input--textarea-premium" style="padding-left: 36px;" maxlength="500" rows="3" placeholder="Например: хочу попасть к топ-мастеру Александру во второй половине дня..."></textarea>
                            </div>
                            <span asp-validation-for="Input.Comment" class="field-error"></span>
                        </div>
                        
                        <div class="checkbox-container" style="margin-bottom: 2rem;">
                            <label class="checkbox" style="display: flex; align-items: flex-start; gap: 0.5rem; cursor: pointer;">
                                <input asp-for="Input.ConsentGiven" type="checkbox" style="margin-top: 3px;" />
                                <span style="font-size: 0.85rem; line-height: 1.4; color: var(--color-text-muted);">
                                    Я даю свое согласие на обработку моих персональных данных в соответствии с Федеральным законом № 152-ФЗ.
                                </span>
                            </label>
                            <span asp-validation-for="Input.ConsentGiven" class="field-error" style="display: block; margin-top: 0.25rem;"></span>
                        </div>
                    </div>
                    
                    <div class="request-widget-card__footer" style="display: flex; flex-direction: column; gap: 0.75rem;">
                        <button type="submit" class="btn btn--primary btn--full-width">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 4px;">
                                <line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                            </svg>
                            <span>Отправить заявку</span>
                        </button>
                        <a class="btn btn--ghost btn--sm" style="text-align: center;" asp-page="/Index">Вернуться на главную</a>
                    </div>
                </form>
            </div>
        </div>
        
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/form-busy.js" asp-append-version="true"></script>
}

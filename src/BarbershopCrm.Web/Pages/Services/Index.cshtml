@page
@model BarbershopCrm.Web.Pages.Services.IndexModel
@{
    ViewData["Title"] = "Услуги";
    var hasFilters = !string.IsNullOrWhiteSpace(Model.Q)
        || !string.IsNullOrWhiteSpace(Model.Category)
        || Model.MinPrice.HasValue
        || Model.MaxPrice.HasValue
        || Model.MaxDuration.HasValue
        || (!string.IsNullOrWhiteSpace(Model.Sort) && Model.Sort != "name");
}

<header class="page-header">
    <h1>Прайс-лист</h1>
    <p class="muted">Единый прайс на все филиалы сети «Тихий час».</p>
</header>

<form method="get" class="services-filters card">
    <div class="services-filters__row">
        <div class="form-group services-filters__search">
            <label asp-for="Q">Поиск</label>
            <div style="position: relative;">
                <svg style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--color-text-muted); pointer-events: none;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.35-4.35"></path>
                </svg>
                <input asp-for="Q" class="input" type="search" placeholder="например, борода или стрижка"
                       autocomplete="off" style="padding-left: 42px;" />
            </div>
        </div>
        <div class="form-group">
            <label asp-for="Sort">Сортировка</label>
            <select asp-for="Sort" class="input">
                <option value="">По названию</option>
                <option value="price-asc">Цена: дешевле</option>
                <option value="price-desc">Цена: дороже</option>
                <option value="duration-asc">Длительность: короче</option>
            </select>
        </div>
    </div>

    <div class="services-filters__chips" role="tablist" aria-label="Категории">
        <a class="chip @(string.IsNullOrEmpty(Model.Category) ? "chip--active" : "")"
           asp-route-q="@Model.Q"
           asp-route-category=""
           asp-route-minPrice="@Model.MinPrice"
           asp-route-maxPrice="@Model.MaxPrice"
           asp-route-maxDuration="@Model.MaxDuration"
           asp-route-sort="@Model.Sort">Все</a>
        @foreach (var c in Model.Categories)
        {
            <a class="chip @(Model.Category == c.Slug ? "chip--active" : "")"
               asp-route-q="@Model.Q"
               asp-route-category="@c.Slug"
               asp-route-minPrice="@Model.MinPrice"
               asp-route-maxPrice="@Model.MaxPrice"
               asp-route-maxDuration="@Model.MaxDuration"
               asp-route-sort="@Model.Sort">@c.Title</a>
        }
    </div>

    <div class="services-filters__row services-filters__ranges">
        <div class="form-group">
            <label asp-for="MinPrice">Цена от, ₽</label>
            <input asp-for="MinPrice" class="input" type="number" min="0" step="50" inputmode="numeric" />
        </div>
        <div class="form-group">
            <label asp-for="MaxPrice">Цена до, ₽</label>
            <input asp-for="MaxPrice" class="input" type="number" min="0" step="50" inputmode="numeric" />
        </div>
        <div class="form-group">
            <label asp-for="MaxDuration">Длительность до, мин</label>
            <input asp-for="MaxDuration" class="input" type="number" min="0" step="5" inputmode="numeric" />
        </div>
        <div class="form-actions services-filters__actions">
            <button type="submit" class="btn btn--primary">Применить</button>
            @if (hasFilters)
            {
                <a class="btn btn--outline" asp-page="/Services/Index">Сбросить</a>
            }
        </div>
    </div>
</form>

<p class="muted services-summary">
    @if (hasFilters)
    {
        <text>Показано <strong>@Model.VisibleCount</strong> из <strong>@Model.TotalCount</strong> услуг.</text>
    }
    else
    {
        <text>Всего услуг: <strong>@Model.TotalCount</strong>.</text>
    }
</p>

@if (Model.Services.Count == 0)
{
    <p class="muted">По заданным фильтрам ничего не нашлось. Попробуйте смягчить условия.</p>
}
else
{
    <div class="grid-3" style="margin-top: var(--space-3);">
        @foreach (var service in Model.Services)
        {
            <article class="card service-card-enhanced">
                @if (!string.IsNullOrEmpty(service.ImageUrl))
                {
                    <img class="service-card-enhanced__image" src="@service.ImageUrl" alt="" loading="lazy" />
                }
                else
                {
                    <div class="service-card-enhanced__image service-card-enhanced__image--placeholder" aria-hidden="true">
                        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                            <line x1="7" y1="7" x2="7.01" y2="7"></line>
                        </svg>
                    </div>
                }
                <div class="service-card-enhanced__content">
                    <div class="service-card-enhanced__head">
                        <h3 class="service-card-enhanced__title">@service.Name</h3>
                        <span class="service-card-enhanced__badge">@Model.CategoryOfService(service)</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(service.Description))
                    {
                        <p class="service-card-enhanced__description">@service.Description</p>
                    }
                    <div class="service-card-enhanced__footer">
                        <div class="service-card-enhanced__meta">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                            <span class="tnum">@service.DurationMinutes мин</span>
                        </div>
                        <div class="service-card-enhanced__price tnum">@service.Price.ToString("0") ₽</div>
                    </div>
                </div>
            </article>
        }
    </div>
}

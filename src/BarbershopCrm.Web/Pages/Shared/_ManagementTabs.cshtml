@inject ICurrentUserAccessor CurrentUserAccessor
@{
    var currentTab = ViewData["ManagementTab"] as string ?? "";
    var role = CurrentUserAccessor.User?.RoleCode;
    var isOwner = role == RoleCode.Owner;
    var isAdmin = role == RoleCode.Admin;
}

<nav class="manage-tabs" aria-label="Управление">
    <h1 class="manage-tabs__heading">Управление</h1>
    <div class="manage-tabs__list" role="tablist">
        @if (isOwner || isAdmin)
        {
            <a class="manage-tabs__tab @(currentTab == "schedule" ? "is-active" : "")"
               role="tab" aria-selected="@(currentTab == "schedule" ? "true" : "false")"
               asp-page="/Admin/Schedule/Index">
                Расписание
            </a>
            <a class="manage-tabs__tab @(currentTab == "bookings" ? "is-active" : "")"
               role="tab" aria-selected="@(currentTab == "bookings" ? "true" : "false")"
               asp-page="/Admin/Bookings/Index">
                Записи
            </a>
            <a class="manage-tabs__tab @(currentTab == "leads" ? "is-active" : "")"
               role="tab" aria-selected="@(currentTab == "leads" ? "true" : "false")"
               asp-page="/Admin/Leads/Index">
                Заявки
            </a>
            <a class="manage-tabs__tab @(currentTab == "analytics" ? "is-active" : "")"
               role="tab" aria-selected="@(currentTab == "analytics" ? "true" : "false")"
               asp-page="@(isOwner ? "/Owner/Analytics/Index" : "/Admin/Analytics/Index")">
                Аналитика
            </a>
        }
    </div>
</nav>

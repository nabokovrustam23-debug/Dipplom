@page
@model BarbershopCrm.Web.Pages.Account.Loyalty.IndexModel
@{
    ViewData["Title"] = "Программа лояльности";
}

<section class="loyalty-page">
    <!-- Page Header -->
    <div class="loyalty-page__header">
        <a asp-page="/Profile/Index" class="btn btn--ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Назад в профиль
        </a>
        <h1 class="loyalty-page__title">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
            </svg>
            Программа лояльности
        </h1>
    </div>

    <!-- 1. Current Status Card -->
    <div class="card loyalty-status-card">
        <div class="loyalty-status-card__header">
            <div class="loyalty-status-card__tier">
                <div class="loyalty-status-card__tier-icon">
                    @if (Model.LoyaltyInfo.CurrentTier.Code == "Premium")
                    {
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                        </svg>
                    }
                    else if (Model.LoyaltyInfo.CurrentTier.Code == "VIP")
                    {
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                        </svg>
                    }
                    else
                    {
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                        </svg>
                    }
                </div>
                <div class="loyalty-status-card__tier-info">
                    <span class="loyalty-status-card__tier-label">Текущий уровень</span>
                    <h2 class="loyalty-status-card__tier-name">@Model.LoyaltyInfo.CurrentTier.DisplayName</h2>
                </div>
            </div>
            @if (Model.LoyaltyInfo.CurrentTier.DiscountPercent > 0)
            {
                <div class="loyalty-status-card__discount">
                    <span class="loyalty-status-card__discount-value">@Model.LoyaltyInfo.CurrentTier.DiscountPercent%</span>
                    <span class="loyalty-status-card__discount-label">скидка</span>
                </div>
            }
        </div>

        <div class="loyalty-status-card__stats">
            <div class="loyalty-stat">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                </svg>
                <div class="loyalty-stat__content">
                    <span class="loyalty-stat__value">@Model.LoyaltyInfo.CompletedVisits</span>
                    <span class="loyalty-stat__label">завершённых визитов</span>
                </div>
            </div>
        </div>

        <p class="loyalty-status-card__motivation">@Model.LoyaltyInfo.MotivationText</p>
    </div>

    <!-- 2. Progress to Next Level -->
    @if (Model.LoyaltyInfo.NextTier != null)
    {
        <div class="card loyalty-progress-card">
            <h3 class="loyalty-progress-card__title">Прогресс до следующего уровня</h3>
            
            <div class="loyalty-progress-card__target">
                <div class="loyalty-progress-card__target-info">
                    <span class="loyalty-progress-card__target-label">Следующий уровень:</span>
                    <span class="loyalty-progress-card__target-name">@Model.LoyaltyInfo.NextTier.DisplayName</span>
                </div>
                <span class="loyalty-progress-card__target-discount">@Model.LoyaltyInfo.NextTier.DiscountPercent% скидка</span>
            </div>

            @{
                var progressPercent = Model.LoyaltyInfo.VisitsToNextTier > 0 
                    ? (int)((double)Model.LoyaltyInfo.CompletedVisits / (Model.LoyaltyInfo.CompletedVisits + Model.LoyaltyInfo.VisitsToNextTier) * 100)
                    : 100;
            }

            <div class="loyalty-progress-bar">
                <div class="loyalty-progress-bar__track">
                    <div class="loyalty-progress-bar__fill" style="width: @progressPercent%"></div>
                </div>
                <div class="loyalty-progress-bar__labels">
                    <span>@Model.LoyaltyInfo.CompletedVisits</span>
                    <span>@Model.LoyaltyInfo.NextTier.MinVisits</span>
                </div>
            </div>

            <p class="loyalty-progress-card__text">
                Осталось <strong>@Model.LoyaltyInfo.VisitsToNextTier визитов</strong> до повышения уровня
            </p>
        </div>
    }

    <!-- 3. All Tiers Table -->
    <div class="card loyalty-tiers-card">
        <h3 class="loyalty-tiers-card__title">Все уровни программы</h3>
        
        <div class="loyalty-tiers-table">
            <table>
                <thead>
                    <tr>
                        <th>Уровень</th>
                        <th>Визитов</th>
                        <th>Скидка</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tier in Model.AllTiers)
                    {
                        var isCurrent = tier.Code == Model.LoyaltyInfo.CurrentTier.Code;
                        <tr class="@(isCurrent ? "loyalty-tiers-table__row--current" : "")">
                            <td>
                                <div class="loyalty-tiers-table__tier-name">
                                    @if (tier.Code == "Premium")
                                    {
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                                        </svg>
                                    }
                                    else if (tier.Code == "VIP")
                                    {
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="10"></circle>
                                        </svg>
                                    }
                                    @(tier.Code == "Standard" ? "Стандарт" : tier.Code == "VIP" ? "VIP" : "Премиум")
                                    @if (isCurrent)
                                    {
                                        <span class="badge badge--ok">текущий</span>
                                    }
                                </div>
                            </td>
                            <td>от @tier.MinVisits</td>
                            <td><strong>@tier.DiscountPercent%</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- 4. Birthday Bonus -->
    <div class="card loyalty-birthday-card">
        <h3 class="loyalty-birthday-card__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            Бонус в день рождения
        </h3>

        @if (Model.BirthDate.HasValue)
        {
            <div class="loyalty-birthday-card__info">
                <p class="loyalty-birthday-card__text">
                    В течение <strong>±@Model.BirthdayWindowDays дней</strong> от вашего дня рождения 
                    (@Model.BirthDate.Value.ToString("dd.MM")) вы получаете дополнительную скидку 
                    <strong>@Model.BirthdayDiscountPercent%</strong> на все услуги!
                </p>
                <div class="loyalty-birthday-card__bonus">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 12v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-6"></path>
                        <path d="M12 3v9"></path>
                        <path d="m8 8 4-4 4 4"></path>
                    </svg>
                    <span>@Model.BirthdayDiscountPercent% скидка</span>
                </div>
            </div>
        }
        else
        {
            <div class="loyalty-birthday-card__empty">
                <p class="loyalty-birthday-card__text">
                    Укажите дату рождения в профиле, чтобы получать дополнительную скидку 
                    <strong>@Model.BirthdayDiscountPercent%</strong> в день рождения!
                </p>
                <a asp-page="/Profile/Edit" class="btn btn--primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                    </svg>
                    Указать дату рождения
                </a>
            </div>
        }
    </div>

    <!-- 5. Discount History -->
    @if (Model.LoyaltyHistory.DiscountedBookings.Any())
    {
        <div class="card loyalty-history-card">
            <h3 class="loyalty-history-card__title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                История применения скидок
            </h3>

            <div class="loyalty-history-table">
                <table>
                    <thead>
                        <tr>
                            <th>Дата</th>
                            <th>Услуга</th>
                            <th>Филиал</th>
                            <th>Мастер</th>
                            <th>Цена</th>
                            <th>Скидка</th>
                            <th>Итого</th>
                            <th>Тип скидки</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.LoyaltyHistory.DiscountedBookings)
                        {
                            <tr>
                                <td>@row.Date.ToString("dd.MM.yyyy")</td>
                                <td>@row.ServiceName</td>
                                <td>@row.BranchName</td>
                                <td>@row.MasterName</td>
                                <td>@row.BasePrice.ToString("N0") ₽</td>
                                <td class="loyalty-history-table__discount">@row.DiscountPercent%</td>
                                <td><strong>@row.FinalAmount.ToString("N0") ₽</strong></td>
                                <td>
                                    <span class="badge badge--info">@row.DiscountReason</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="loyalty-history-card__summary">
                @{
                    var totalSaved = Model.LoyaltyHistory.DiscountedBookings.Sum(r => r.BasePrice - r.FinalAmount);
                }
                <p class="loyalty-history-card__summary-text">
                    Всего сэкономлено: <strong>@totalSaved.ToString("N0") ₽</strong>
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="card loyalty-history-card loyalty-history-card--empty">
            <div class="loyalty-history-card__empty-state">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="8" x2="12" y2="12"></line>
                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
                <h4>История скидок пока пуста</h4>
                <p>Совершите визит, чтобы начать получать скидки по программе лояльности</p>
                <a asp-page="/BookingFlow/New" class="btn btn--primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    Записаться на услугу
                </a>
            </div>
        </div>
    }
</section>


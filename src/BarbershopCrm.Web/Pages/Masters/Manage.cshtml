@page
@model BarbershopCrm.Web.Pages.Masters.ManageModel
@{
    ViewData["Title"] = "Управление · Мастера";
    ViewData["ManagementTab"] = "masters";
    var isOwner = Model.Current?.RoleCode == RoleCode.Owner;
}

<partial name="_ManagementTabs" />

<section class="management-section">
    <div class="management-header">
        <div class="management-header__content">
            <h2 id="masters-list-heading">Команда мастеров</h2>
            <p class="management-header__subtitle">Управление специалистами и их услугами</p>
        </div>
        <div class="management-header__stats">
            <div class="stat-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
                <div class="stat-badge__content">
                    <span class="stat-badge__value">@Model.Masters.Count</span>
                    <span class="stat-badge__label">@(Model.Masters.Count == 1 ? "мастер" : Model.Masters.Count < 5 ? "мастера" : "мастеров")</span>
                </div>
            </div>
            <div class="stat-badge stat-badge--success">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <div class="stat-badge__content">
                    <span class="stat-badge__value">@Model.Masters.Count(m => m.IsActive)</span>
                    <span class="stat-badge__label">активных</span>
                </div>
            </div>
        </div>
    </div>

    <div class="masters-toolbar">
        <label class="filter-checkbox">
            <input type="checkbox" id="hideInactiveMasters" />
            <span>Скрыть неактивных</span>
        </label>
        @if (isOwner)
        {
            <a asp-page="Create" class="btn btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                Добавить мастера
            </a>
        }
    </div>

    @if (Model.Masters.Count == 0)
    {
        <div class="empty-state">
            <svg class="empty-state__icon" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            <h3 class="empty-state__title">Мастеров пока нет</h3>
            <p class="empty-state__text">Добавьте первого специалиста в вашу команду</p>
        </div>
    }
    else
    {
        <div class="masters-grid" id="mastersGrid">
            @foreach (var m in Model.Masters)
            {
                <article class="master-card @(m.IsActive ? "" : "master-card--inactive")" data-status="@(m.IsActive ? "active" : "inactive")">
                    <div class="master-card__header">
                        <div class="master-card__avatar">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                        </div>
                        <div class="master-card__info">
                            <h3 class="master-card__name">@m.Persona.FullName</h3>
                            <div class="master-card__meta">
                                <span class="master-card__branch">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                        <circle cx="12" cy="10" r="3"></circle>
                                    </svg>
                                    @m.Branch.Name
                                </span>
                            </div>
                        </div>
                        <div class="master-card__status">
                            @if (m.IsActive)
                            {
                                <span class="badge badge--ok">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                    Активен
                                </span>
                            }
                            else
                            {
                                <span class="badge">Неактивен</span>
                            }
                        </div>
                    </div>

                    @if (m.MasterServices.Any())
                    {
                        <div class="master-card__services">
                            <div class="master-card__services-label">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                                    <line x1="7" y1="7" x2="7.01" y2="7"></line>
                                </svg>
                                Услуги:
                            </div>
                            <div class="master-card__services-list">
                                @foreach (var ms in m.MasterServices.Take(3))
                                {
                                    <span class="service-tag">@ms.Service.Name</span>
                                }
                                @if (m.MasterServices.Count > 3)
                                {
                                    <span class="service-tag service-tag--more">+@(m.MasterServices.Count - 3)</span>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="master-card__services master-card__services--empty">
                            <span class="faint">Услуги не назначены</span>
                        </div>
                    }

                    <div class="master-card__actions">
                        <a asp-page="Edit" asp-route-id="@m.MasterId" class="btn btn--outline btn--block" aria-label="Изменить мастера @m.Persona.FullName">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                            </svg>
                            Редактировать
                        </a>
                    </div>
                </article>
            }
        </div>
    }
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const hideInactiveCheckbox = document.getElementById('hideInactiveMasters');
            const masterCards = document.querySelectorAll('.master-card');

            hideInactiveCheckbox.addEventListener('change', function() {
                const hideInactive = this.checked;
                
                masterCards.forEach(card => {
                    const status = card.dataset.status;
                    if (hideInactive && status === 'inactive') {
                        card.style.display = 'none';
                    } else {
                        card.style.display = '';
                    }
                });
            });
        });
    </script>
}

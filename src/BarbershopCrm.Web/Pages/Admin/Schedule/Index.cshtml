@page
@using BarbershopCrm.Domain.Enums
@model BarbershopCrm.Web.Pages.Admin.Schedule.IndexModel
@{
    ViewData["Title"] = "Расписание мастеров — Тихого Часа";
    ViewData["ManagementTab"] = "schedule";
    var isOwner = Model.Current?.RoleCode == RoleCode.Owner;
    var safeDate = Model.DateValue > DateOnly.MinValue ? Model.DateValue : DateOnly.FromDateTime(DateTime.Today);
    var prevDay = safeDate.AddDays(-1).ToString("yyyy-MM-dd");
    var nextDay = safeDate.AddDays(1).ToString("yyyy-MM-dd");
    var today = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");
}

<partial name="_ManagementTabs" />

<section class="management-section animate-fade-in">
    
    <div class="schedule-header">
        <div class="schedule-header__content">
            <h2>Расписание мастеров</h2>
            <div class="schedule-header__meta">
                @if (Model.CurrentBranch is not null)
                {
                    <span class="schedule-meta-chip">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                            <circle cx="12" cy="10" r="3"></circle>
                        </svg>
                        <span>@Model.CurrentBranch.Name</span>
                    </span>
                }
                <span class="schedule-meta-chip schedule-meta-chip--date">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    <span>@BarbershopCrm.Web.Pages.Admin.Schedule.IndexModel.FormatRussianDate(Model.DateValue)</span>
                </span>
            </div>
        </div>

        <form method="get" class="schedule-toolbar-panel">
            @if (isOwner && Model.Branches.Count > 1)
            {
                <div class="toolbar-control-box">
                    <select id="branch-pick" name="branchId" class="input input--filter-compact" onchange="this.form.submit()">
                        @foreach (var b in Model.Branches)
                        {
                            <option value="@b.BranchId" selected="@(b.BranchId == Model.BranchId)">@b.Name</option>
                        }
                    </select>
                </div>
            }
            
            <div class="toolbar-control-box toolbar-navigation-pills">
                <button type="submit" name="Date" value="@prevDay" class="btn btn--outline-compact btn--icon" title="Предыдущий день">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                </button>
                <button type="submit" name="Date" value="@today" class="btn btn--accent-compact">Сегодня</button>
                <button type="submit" name="Date" value="@nextDay" class="btn btn--outline-compact btn--icon" title="Следующий день">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                </button>
            </div>
            
            <div class="toolbar-control-box">
                <input type="date" id="Date" name="Date" class="input input--filter-compact input--date-picker" value="@Model.DateValue.ToString("yyyy-MM-dd")" onchange="this.form.submit()" />
            </div>
        </form>
    </div>

    @if (TempData["Error"] is string errMsg)
    {
        <div class="alert alert--error alert--modern">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            <span>@errMsg</span>
        </div>
    }
    @if (TempData["Success"] is string succMsg)
    {
        <div class="alert alert--success alert--modern">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>@succMsg</span>
        </div>
    }

    @if (Model.BranchId is null || Model.Masters.Count == 0)
    {
        <div class="premium-empty-state">
            <div class="empty-state-illustration">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
            </div>
            <h4>Нет активных мастеров</h4>
            <p>В выбранном филиале отсутствуют графики мастеров на текущую дату. Добавьте персонал в панели управления.</p>
        </div>
    }
    else if (Model.Agenda is not null)
    {
        <div class="schedule-timeline-wrapper">
            <partial name="_ScheduleDayAgenda" model="Model.Agenda" />
        </div>
    }
</section>

@section Scripts {
    <script src="~/js/form-busy.js" asp-append-version="true"></script>
}

@page "/Owner/Analytics"
@model BarbershopCrm.Web.Pages.Owner.Analytics.IndexModel
@{
    ViewData["Title"] = "Аналитика сети — Тихого Часа";
    ViewData["ManagementTab"] = "analytics";
}

<partial name="_ManagementTabs" />

<section class="analytics-header">
    <div class="analytics-header__content">
        <span class="analytics-header__badge">Управление сетью</span>
        <h2>Аналитика — @(Model.Snapshot?.BranchName ?? "Вся сеть")</h2>
        <p class="analytics-header__subtitle">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-geo">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>@(Model.Snapshot?.BranchName ?? "Все доступные филиалы компании")</span>
        </p>
    </div>
    <div class="management-header__actions">
        <a asp-page="/Owner/Analytics/Clients"
           asp-route-from="@Model.FromValue.ToString("yyyy-MM-dd")"
           asp-route-to="@Model.ToValue.ToString("yyyy-MM-dd")"
           asp-route-branchid="@Model.BranchId"
           class="btn btn--primary btn--with-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            <span>Аналитика клиентов</span>
        </a>
        <a asp-page="/Owner/Analytics/Compare"
           asp-route-from="@Model.FromValue.ToString("yyyy-MM-dd")"
           asp-route-to="@Model.ToValue.ToString("yyyy-MM-dd")"
           class="btn btn--outline btn--with-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="20" x2="18" y2="10"></line>
                <line x1="12" y1="20" x2="12" y2="4"></line>
                <line x1="6" y1="20" x2="6" y2="14"></line>
            </svg>
            <span>Сравнить филиалы</span>
        </a>
    </div>
</section>

<div class="analytics-controls-layout">
    
    <section class="analytics-filters-card">
        <div class="analytics-filters-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
            </svg>
            <h3>Параметры отчета</h3>
        </div>
        
        <form method="get" class="analytics-filters">
            <div class="filter-group">
                <label for="BranchId">
                    <span>Филиал точки</span>
                </label>
                <div class="input-wrapper">
                    <select id="BranchId" name="BranchId" class="input input--filter">
                        <option value="">Вся сеть барбершопов</option>
                        @foreach (var b in Model.BranchOptions)
                        {
                            <option value="@b.Value" selected="@(Model.BranchId?.ToString() == b.Value)">@b.Text</option>
                        }
                    </select>
                </div>
            </div>
            
            <div class="filter-group">
                <label for="From"><span>Дата начала</span></label>
                <input id="From" name="From" type="date" class="input input--filter" value="@Model.FromValue.ToString("yyyy-MM-dd")" />
            </div>
        
            <div class="filter-group">
                <label for="To"><span>Дата окончания</span></label>
                <input id="To" name="To" type="date" class="input input--filter" value="@Model.ToValue.ToString("yyyy-MM-dd")" />
            </div>
            
            <div class="filter-actions">
                <button type="submit" class="btn btn--accent btn--filter">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    <span>Обновить данные</span>
                </button>
                <a asp-page="/Owner/Analytics/Index" class="btn btn--ghost btn--filter" title="Сбросить фильтры">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M23 4v6h-6M1 20v-6h6"></path>
                        <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                    </svg>
                </a>
            </div>
        </form>
    </section>

    <section class="export-banner-mini">
        <div class="export-banner-mini__content">
            <div class="export-banner-mini__text">
                <h4>Выгрузка логов</h4>
                <p>Записи за выбранный период доступны в формате таблицы Excel (CSV, UTF-8 с BOM).</p>
            </div>
        </div>
        <a asp-page="/Owner/Analytics/Index" asp-page-handler="Export"
           asp-route-from="@Model.FromValue.ToString("yyyy-MM-dd")"
           asp-route-to="@Model.ToValue.ToString("yyyy-MM-dd")"
           asp-route-branchid="@Model.BranchId"
           class="btn btn--outline-success btn--export">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Скачать журнал</span>
        </a>
    </section>
</div>

@if (Model.Snapshot is not null)
{
    <div class="dashboard-wrapper animate-fade-in">
        <partial name="_AnalyticsDashboard" model="Model.Snapshot" />
    </div>
}

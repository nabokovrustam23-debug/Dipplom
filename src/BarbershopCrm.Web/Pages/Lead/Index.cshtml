@page "/Lead"
@model BarbershopCrm.Web.Pages.Lead.IndexModel
@{
    ViewData["Title"] = "Оставить заявку";
}

<div class="lead-page">
    <div class="lead-page__container">
        <!-- Left side: Info -->
        <div class="lead-page__info">
            <div class="lead-page__badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
                Обратный звонок
            </div>
            
            <h1 class="lead-page__title">Перезвоним и поможем выбрать слот</h1>
            <p class="lead-page__description">
                Оставьте заявку — администратор свяжется с вами в течение 15 минут и подберёт удобное время для визита.
            </p>
            
            <div class="lead-page__features">
                <div class="lead-feature">
                    <div class="lead-feature__icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </div>
                    <div class="lead-feature__text">
                        <strong>Быстрый ответ</strong>
                        <span>Перезвоним в течение 15 минут</span>
                    </div>
                </div>
                
                <div class="lead-feature">
                    <div class="lead-feature__icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </div>
                    <div class="lead-feature__text">
                        <strong>Подбор времени</strong>
                        <span>Поможем выбрать удобный слот</span>
                    </div>
                </div>
                
                <div class="lead-feature">
                    <div class="lead-feature__icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </div>
                    <div class="lead-feature__text">
                        <strong>Консультация</strong>
                        <span>Ответим на все вопросы</span>
                    </div>
                </div>
            </div>
            
            <div class="lead-page__alt">
                <p>Предпочитаете записаться самостоятельно?</p>
                <a asp-page="/BookingFlow/New" class="btn btn--outline">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    Записаться онлайн
                </a>
            </div>
        </div>
        
        <!-- Right side: Form -->
        <div class="lead-page__form">
            <div class="lead-form-card">
                <div class="lead-form-card__header">
                    <h2>Оставить заявку</h2>
                    <p>Заполните форму, и мы свяжемся с вами</p>
                </div>
                
                <div asp-validation-summary="All" class="alert alert--error"></div>
                
                <form method="post" data-busy>
                    <div class="lead-form-card__body">
                        <div class="form-group">
                            <label asp-for="Input.Name">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                                Ваше имя
                            </label>
                            <input asp-for="Input.Name" class="input" autocomplete="name" placeholder="Иван Иванов" />
                            <span asp-validation-for="Input.Name" class="field-validation-error"></span>
                        </div>
                        
                        <div class="form-group">
                            <label asp-for="Input.Phone">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                                </svg>
                                Телефон
                            </label>
                            <input asp-for="Input.Phone" class="input" autocomplete="tel" placeholder="+7 (900) 000-00-00" />
                            <span asp-validation-for="Input.Phone" class="field-validation-error"></span>
                        </div>
                        
                        <div class="form-group">
                            <label asp-for="Input.PreferredBranchId">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                    <circle cx="12" cy="10" r="3"></circle>
                                </svg>
                                Предпочитаемый филиал
                            </label>
                            <select asp-for="Input.PreferredBranchId" asp-items="Model.Branches" class="input" required>
                                <option value="">— выберите филиал —</option>
                            </select>
                            <span asp-validation-for="Input.PreferredBranchId" class="field-validation-error"></span>
                        </div>
                        
                        <div class="form-group">
                            <label asp-for="Input.Comment">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                                </svg>
                                Комментарий <span class="optional">(необязательно)</span>
                            </label>
                            <textarea asp-for="Input.Comment" class="input" maxlength="500" rows="3" placeholder="Укажите желаемое время или другие пожелания"></textarea>
                            <span asp-validation-for="Input.Comment" class="field-validation-error"></span>
                        </div>
                        
                        <div class="form-group">
                            <label class="check">
                                <input asp-for="Input.ConsentGiven" type="checkbox" />
                                <span>Я согласен на обработку персональных данных в соответствии с 152-ФЗ</span>
                            </label>
                            <span asp-validation-for="Input.ConsentGiven" class="field-validation-error"></span>
                        </div>
                    </div>
                    
                    <div class="lead-form-card__footer">
                        <button type="submit" class="btn btn--primary btn--large">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="22" y1="2" x2="11" y2="13"></line>
                                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                            </svg>
                            Отправить заявку
                        </button>
                        <a class="btn btn--ghost" asp-page="/Index">Вернуться на главную</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/form-busy.js" asp-append-version="true"></script>
}

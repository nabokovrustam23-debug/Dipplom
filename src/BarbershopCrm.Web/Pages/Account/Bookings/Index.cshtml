@page "/Account/Bookings"
@using BarbershopCrm.Domain.Enums
@model BarbershopCrm.Web.Pages.Account.Bookings.IndexModel
@{
    ViewData["Title"] = "Мои записи";
    var activeTab = string.IsNullOrEmpty(Model.Tab) || Model.Tab == "active" ? "active" : "history";
}

<div class="bookings-page">
    <header class="bookings-header">
        <div class="bookings-header__content">
            <h1>Мои записи</h1>
            <p class="muted">Управляйте своими визитами в барбершоп</p>
            <p class="bookings-header__hint muted">
                <strong>Онлайн-запись</strong> — если уже знаете услугу, мастера и время.
                <strong>Заявка</strong> — если нужен звонок администратора или не нашли слот.
            </p>
        </div>
        <div class="bookings-header__actions">
            <a asp-page="/BookingFlow/New" class="btn btn--primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                Новая запись
            </a>
            <a asp-page="/Lead/Index" class="btn btn--outline">Оставить заявку</a>
        </div>
    </header>

    <!-- Tabs -->
    <div class="bookings-tabs">
        <a class="bookings-tab @(activeTab == "active" ? "bookings-tab--active" : "")" 
           asp-route-tab="active">
            Активные
            @if (Model.Active.Any())
            {
                <span class="bookings-tab__badge">@Model.Active.Count</span>
            }
        </a>
        <a class="bookings-tab @(activeTab == "history" ? "bookings-tab--active" : "")" 
           asp-route-tab="history">
            История
        </a>
    </div>

    @if (activeTab == "active")
    {
        @if (!Model.Active.Any())
        {
            <div class="bookings-empty">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                <p>У вас нет активных записей</p>
                <p class="muted">Запишитесь на удобное время прямо сейчас</p>
                <a asp-page="/BookingFlow/New" class="btn btn--primary" style="margin-top: var(--space-4);">Записаться онлайн</a>
            </div>
        }
        else
        {
            <div class="bookings-info">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="16" x2="12" y2="12"></line>
                    <line x1="12" y1="8" x2="12.01" y2="8"></line>
                </svg>
                <span>Отменить запись можно не позднее, чем за <strong>@Model.CancelCutoffHours ч</strong> до начала</span>
            </div>
            
            <div class="bookings-grid">
                @foreach (var b in Model.Active.OrderBy(x => x.StartDateTime))
                {
                    var canCancel = (b.StartDateTime - DateTime.UtcNow).TotalHours >= Model.CancelCutoffHours;
                    var isUpcoming = b.StartDateTime > DateTime.UtcNow;
                    var statusClass = b.Status.ToLowerInvariant();
                    
                    <article class="booking-card booking-card--@statusClass">
                        <div class="booking-card__header">
                            <div class="booking-card__date">
                                <div class="booking-card__day">@b.StartDateTime.ToString("dd")</div>
                                <div class="booking-card__month">@b.StartDateTime.ToString("MMM", new System.Globalization.CultureInfo("ru-RU"))</div>
                            </div>
                            <div class="booking-card__status">
                                <span class="badge badge--@statusClass">@StatusLabels.BookingStatus(b.Status)</span>
                            </div>
                        </div>
                        
                        <div class="booking-card__body">
                            <div class="booking-card__time">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <polyline points="12 6 12 12 16 14"></polyline>
                                </svg>
                                <span class="tnum">@b.StartDateTime.ToString("HH:mm")</span>
                                <span class="muted">· @b.DurationMinutes мин</span>
                            </div>
                            
                            <div class="booking-card__service">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                                    <line x1="7" y1="7" x2="7.01" y2="7"></line>
                                </svg>
                                <span>@b.Service.Name</span>
                            </div>
                            
                            <div class="booking-card__master">
                                <div class="booking-card__avatar">@(b.Master.Persona.LastName.Length > 0 ? b.Master.Persona.LastName[0] : '?')</div>
                                <span>@b.Master.Persona.ShortName</span>
                            </div>
                            
                            <div class="booking-card__branch">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                    <circle cx="12" cy="10" r="3"></circle>
                                </svg>
                                <span>@b.Branch.Name</span>
                            </div>
                            
                            <div class="booking-card__price">
                                @{
                                    var bFinal = b.FinalPrice;
                                }
                                @if (b.LoyaltyDiscountPercent > 0)
                                {
                                    <span class="tnum" style="text-decoration: line-through; color: var(--color-text-muted);">@b.PriceSnapshot.ToString("0") ₽</span>
                                    <span class="tnum" style="color: var(--color-success); font-weight: 600;">@bFinal.ToString("0") ₽</span>
                                    <span class="schedule-agenda__badge schedule-agenda__badge--discount">-@b.LoyaltyDiscountPercent%</span>
                                }
                                else
                                {
                                    <span class="tnum">@b.PriceSnapshot.ToString("0") ₽</span>
                                }
                            </div>
                            @if (b.Status == BookingStatus.Created)
                            {
                                <p class="booking-card__next muted">Дальше: приходите вовремя или дождитесь подтверждения от салона (если требуется).</p>
                            }
                            else if (b.Status == BookingStatus.Confirmed)
                            {
                                <p class="booking-card__next muted">Дальше: ждём вас в @b.Branch.Name в указанное время.</p>
                            }
                        </div>
                        
                        @if (canCancel && isUpcoming)
                        {
                            <div class="booking-card__footer">
                                <form method="post" asp-page-handler="Cancel" asp-route-id="@b.BookingId" data-busy 
                                      onsubmit="return confirm('Вы уверены, что хотите отменить запись?')" 
                                      style="width: 100%;">
                                    <button type="submit" class="btn btn--outline btn--small" style="width: 100%;">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <line x1="18" y1="6" x2="6" y2="18"></line>
                                            <line x1="6" y1="6" x2="18" y2="18"></line>
                                        </svg>
                                        Отменить запись
                                    </button>
                                </form>
                            </div>
                        }
                        else if (!canCancel && isUpcoming)
                        {
                            <div class="booking-card__footer">
                                <div class="booking-card__notice">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"></circle>
                                        <line x1="12" y1="8" x2="12" y2="12"></line>
                                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                                    </svg>
                                    Отмена недоступна (менее @Model.CancelCutoffHours ч до визита)
                                </div>
                            </div>
                        }
                    </article>
                }
            </div>
        }
    }
    else
    {
        @if (!Model.Past.Any())
        {
            <div class="bookings-empty">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                <p>История записей пуста</p>
                <p class="muted">Здесь будут отображаться ваши прошедшие визиты</p>
            </div>
        }
        else
        {
            <div class="bookings-grid">
                @foreach (var b in Model.Past.OrderByDescending(x => x.StartDateTime))
                {
                    var statusClass = b.Status.ToLowerInvariant();
                    
                    <article class="booking-card booking-card--past booking-card--@statusClass">
                        <div class="booking-card__header">
                            <div class="booking-card__date">
                                <div class="booking-card__day">@b.StartDateTime.ToString("dd")</div>
                                <div class="booking-card__month">@b.StartDateTime.ToString("MMM", new System.Globalization.CultureInfo("ru-RU"))</div>
                            </div>
                            <div class="booking-card__status">
                                <span class="badge badge--@statusClass">@StatusLabels.BookingStatus(b.Status)</span>
                            </div>
                        </div>
                        
                        <div class="booking-card__body">
                            <div class="booking-card__time">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <polyline points="12 6 12 12 16 14"></polyline>
                                </svg>
                                <span class="tnum">@b.StartDateTime.ToString("HH:mm")</span>
                                <span class="muted">· @b.DurationMinutes мин</span>
                            </div>
                            
                            <div class="booking-card__service">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                                    <line x1="7" y1="7" x2="7.01" y2="7"></line>
                                </svg>
                                <span>@b.Service.Name</span>
                            </div>
                            
                            <div class="booking-card__master">
                                <div class="booking-card__avatar">@(b.Master.Persona.LastName.Length > 0 ? b.Master.Persona.LastName[0] : '?')</div>
                                <span>@b.Master.Persona.ShortName</span>
                            </div>
                            
                            <div class="booking-card__branch">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                    <circle cx="12" cy="10" r="3"></circle>
                                </svg>
                                <span>@b.Branch.Name</span>
                            </div>
                            
                            <div class="booking-card__price">
                                @{
                                    var bFinal = b.FinalPrice;
                                }
                                @if (b.LoyaltyDiscountPercent > 0)
                                {
                                    <span class="tnum" style="text-decoration: line-through; color: var(--color-text-muted);">@b.PriceSnapshot.ToString("0") ₽</span>
                                    <span class="tnum" style="color: var(--color-success); font-weight: 600;">@bFinal.ToString("0") ₽</span>
                                    <span class="schedule-agenda__badge schedule-agenda__badge--discount">-@b.LoyaltyDiscountPercent%</span>
                                }
                                else
                                {
                                    <span class="tnum">@b.PriceSnapshot.ToString("0") ₽</span>
                                }
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    }
</div>

@section Scripts {
    <script src="~/js/form-busy.js" asp-append-version="true"></script>
}

@page
@model BarbershopCrm.Web.Pages.Account.Loyalty.IndexModel
@{
    ViewData["Title"] = "Программа лояльности — Тихого Часа";
}

<section class="loyalty-premium-hub-section animate-fade-in">
    
    <div class="analytics-header" style="margin-bottom: 2.5rem;">
        <div class="analytics-header__content">
            <span class="analytics-header__badge">Клуб привилегий</span>
            <h2>Программа лояльности сети</h2>
            <p class="analytics-header__subtitle">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                </svg>
                <span>Накапливайте визиты и получайте персональные скидки на весь перечень услуг</span>
            </p>
        </div>
        <div class="management-header__actions">
            <a asp-page="/Profile/Index" class="btn btn--outline btn--with-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                <span>Вернуться в профиль</span>
            </a>
        </div>
    </div>

    <div class="visual-chart-box visual-chart-box--full loyalty-club-hero-card" style="margin-bottom: 2rem;">
        <div class="loyalty-club-hero-card__layout">
            <div class="loyalty-club-hero-card__main-info">
                <div class="tier-visual-marker-box">
                    @if (Model.LoyaltyInfo.CurrentTier.Code == "Premium" || Model.LoyaltyInfo.CurrentTier.Code == "VIP")
                    {
                        <div class="tier-glow-icon icon-color-gold">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                            </svg>
                        </div>
                    }
                    else
                    {
                        <div class="tier-glow-icon icon-color-blue">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <circle cx="12" cy="12" r="10"></circle><path d="M12 8v8M8 12h8"/>
                            </svg>
                        </div>
                    }
                    <div class="tier-text-block">
                        <small>Ваш персональный ранг</small>
                        <h3>@Model.LoyaltyInfo.CurrentTier.DisplayName</h3>
                    </div>
                </div>
                
                <p class="loyalty-motivation-speech">@Model.LoyaltyInfo.MotivationText</p>
            </div>

            <div class="loyalty-club-hero-card__metrics-panel">
                @if (Model.LoyaltyInfo.CurrentTier.DiscountPercent > 0)
                {
                    <div class="premium-discount-badge-box">
                        <span class="discount-value">@Model.LoyaltyInfo.CurrentTier.DiscountPercent%</span>
                        <small class="discount-label">постоянная скидка</small>
                    </div>
                }
                
                <div class="counter-inline-node">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                    </svg>
                    <div class="counter-text">
                        <strong>@Model.LoyaltyInfo.CompletedVisits</strong>
                        <small>завершённых сессий у кресла</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.LoyaltyInfo.NextTier != null)
    {
        <section class="visual-chart-box visual-chart-box--full loyalty-progress-card" style="margin-bottom: 2rem;">
            <div class="visual-chart-box__header" style="padding:0; margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                <div style="display:flex; flex-direction:column;">
                    <h4 style="margin:0;">Прогресс до следующего грейда</h4>
                    <p class="visual-chart-box__hint" style="margin:0;">Следующий ранг: <strong>@Model.LoyaltyInfo.NextTier.DisplayName</strong></p>
                </div>
                <span class="badge badge--success" style="font-size: 0.85rem; padding: 0.5rem 0.75rem;">
                    Цель: скидка @Model.LoyaltyInfo.NextTier.DiscountPercent%
                </span>
            </div>

            @{
                var progressPercent = Model.LoyaltyInfo.VisitsToNextTier > 0 
                    ? (int)((double)Model.LoyaltyInfo.CompletedVisits / (Model.LoyaltyInfo.CompletedVisits + Model.LoyaltyInfo.VisitsToNextTier) * 100)
                    : 100;
            }

            <div class="custom-progress-item" style="margin: 1.5rem 0 1rem 0;">
                <div class="custom-progress-item__track" style="height: 10px;">
                    <div class="custom-progress-item__bar bar-status-completed" style="width: @progressPercent%"></div>
                </div>
                <div class="custom-progress-item__info" style="margin-top: 0.5rem;">
                    <span class="item-label" style="font-size: 0.85rem; color: var(--color-text-muted);">Текущая планка: @Model.LoyaltyInfo.CompletedVisits</span>
                    <span class="item-numeric" style="font-size: 0.85rem; color: var(--color-text-main);">Порог перехода: @Model.LoyaltyInfo.NextTier.MinVisits</span>
                </div>
            </div>

            <p class="loyalty-remaining-text" style="font-size: 0.9rem; color: var(--color-text-muted); margin: 0;">
                Для автоматического повышения статуса осталось выполнить ещё <strong>@Model.LoyaltyInfo.VisitsToNextTier визитов</strong>.
            </p>
        </section>
    }

    <div class="analytics-visualization-row" style="margin-bottom: 2rem; gap: 2rem;">
        
        <section class="visual-chart-box" style="flex: 1 1 450px;">
            <div class="visual-chart-box__header" style="padding:0; margin-bottom: 1.5rem;">
                <h4>Таблица рангов клуба привилегий</h4>
            </div>
            
            <div class="premium-table-container">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>Уровень программы</th>
                            <th style="text-align: center;">Порог сессий</th>
                            <th style="text-align: right;">Скидка грейда</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tier in Model.AllTiers)
                        {
                            var isCurrent = tier.Code == Model.LoyaltyInfo.CurrentTier.Code;
                            <tr class="@(isCurrent ? "table-row-highlighted-ok" : "")">
                                <td>
                                    <div class="table-client-profile" style="gap: 0.5rem;">
                                        <div class="table-client-avatar" style="width:24px; height:24px; font-size: 0.75rem; background-color: @(isCurrent ? "var(--color-success)" : "var(--color-border)"); color: @(isCurrent ? "#fff" : "var(--color-text-muted)");">
                                            @tier.Code.Substring(0,1)
                                        </div>
                                        <strong style="font-size: 0.9rem;">@tier.Code</strong>
                                        @if (isCurrent)
                                        {
                                            <span class="badge badge--success" style="font-size:0.7rem; padding: 0.15rem 0.4rem;">Активен</span>
                                        }
                                    </div>
                                </td>
                                <td style="text-align: center;" class="table-numeric-gray-bold">от @tier.MinVisits</td>
                                <td style="text-align: right;" class="table-currency-highlight text-color-green">@tier.DiscountPercent%</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="visual-chart-box loyalty-birthday-coupon-card" style="flex: 1 1 350px; display: flex; flex-direction: column;">
            <div class="visual-chart-box__header" style="padding:0; margin-bottom: 1.5rem;">
                <div class="header-icon-title">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 12v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-6"></path><path d="M12 3v9"></path><path d="m8 8 4-4 4 4"></path>
                    </svg>
                    <h4>Именинникам «Тихого Часа»</h4>
                </div>
            </div>

            <div class="birthday-coupon-body-layout" style="flex-grow: 1; display: flex; flex-direction: column; justify-content: center;">
                @if (Model.BirthDate.HasValue)
                {
                    <p class="birthday-coupon-desc" style="font-size: 0.9rem; line-height: 1.5; color: var(--color-text-muted); margin-bottom: 1.5rem;">
                        В праздничный коридор <strong>±@Model.BirthdayWindowDays дней</strong> от вашего дня рождения 
                        (<strong class="text-color-main">@Model.BirthDate.Value.ToString("dd.MM")</strong>) вам автоматически начисляется дополнительная скидка 
                        <strong>@Model.BirthdayDiscountPercent%</strong> на любые позиции нашего прайс-листа!
                    </p>
                    <div class="birthday-coupon-ticket" style="background-color: var(--color-primary-soft); color: var(--color-primary); padding: 1rem; border-radius: var(--radius-md); text-align: center; border: 1px dashed var(--color-primary);">
                        <strong style="font-size: 1.25rem; font-weight: 700; letter-spacing: 0.5px;">+@Model.BirthdayDiscountPercent% К СКИДКЕ</strong>
                    </div>
                }
                else
                {
                    <p class="birthday-coupon-desc" style="font-size: 0.9rem; line-height: 1.5; color: var(--color-text-muted); margin-bottom: 1.5rem;">
                        Укажите дату рождения в личной анкете профиля гостя, чтобы активировать дополнительную праздничную скидку 
                        <strong>@Model.BirthdayDiscountPercent%</strong> во время вашего праздника!
                    </p>
                    <a asp-page="/Profile/Edit" class="btn btn--primary btn--sm btn--full-width" style="margin-top: auto;">
                        <span>Заполнить дату рождения</span>
                    </a>
                }
            </div>
        </section>
    </div>

    <section class="visual-chart-box visual-chart-box--full">
        <div class="visual-chart-box__header" style="padding:0; margin-bottom: 2rem;">
            <div class="header-icon-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                <h4>История закрытых касс и экономии</h4>
            </div>
            <p class="visual-chart-box__hint">Архивный журнал всех ваших выполненных сессий, к которым применялись дисконтные программы сети</p>
        </div>

        @if (Model.LoyaltyHistory.DiscountedBookings.Any())
        {
            <div class="premium-table-container">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th style="width: 110px;">Дата сеанса</th>
                            <th>Наименование услуги</th>
                            <th>Филиал сети</th>
                            <th>Специалист кресла</th>
                            <th style="text-align: right;">Прайс</th>
                            <th style="text-align: center;">Скидка</th>
                            <th style="text-align: right;">Оплачено</th>
                            <th>Основание применения</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.LoyaltyHistory.DiscountedBookings)
                        {
                            <tr>
                                <td class="table-numeric-gray-bold">@row.Date.ToString("dd.MM.yyyy")</td>
                                <td><strong>@row.ServiceName</strong></td>
                                <td>@row.BranchName</td>
                                <td>@row.MasterName</td>
                                <td style="text-align: right;" class="table-numeric-gray-bold">@row.BasePrice.ToString("N0") ₽</td>
                                <td style="text-align: center;" class="table-numeric-bold text-color-green">@row.DiscountPercent%</td>
                                <td style="text-align: right;" class="table-currency-highlight">@row.FinalAmount.ToString("N0") ₽</td>
                                <td>
                                    <span class="badge badge--neutral" style="font-size: 0.75rem;">
                                        @{
                                            var reasonLabel = row.DiscountReason switch {
                                                "Tier" => "Программа лояльности",
                                                "Birthday" => "День рождения",
                                                "FirstVisit" => "Первый визит",
                                                _ => row.DiscountReason
                                            };
                                        }
                                        @reasonLabel
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="loyalty-history-card__summary" style="margin-top: 2rem; display: flex; justify-content: flex-end; padding: 1rem 1.5rem; background-color: var(--color-background-card); border-radius: var(--radius-md); border-left: 4px solid var(--color-success);">
                <p style="margin: 0; font-size: 1rem; color: var(--color-text-main);">
                    Суммарный объем сэкономленных инвестиций в ваш стиль: <strong class="text-color-green" style="font-size: 1.15rem; font-weight: 700; margin-left: 0.5rem;">@Model.LoyaltyHistory.DiscountedBookings.Sum(r => r.BasePrice - r.FinalAmount).ToString("N0") ₽</strong>
                </p>
            </div>
        }
        else
        {
            <div class="master-agenda-empty" style="padding: 4rem 0;">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" style="color: var(--color-text-muted); margin-bottom: 1rem;">
                    <circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
                <h4 style="margin: 0 0 0.5rem 0; font-size: 1.1rem; font-weight: 600; color: var(--color-text-main);">Журнал экономии пока пуст</h4>
                <p style="margin: 0 0 1.5rem 0; font-size: 0.9rem; color: var(--color-text-muted);">Выполненные визиты со скидками в вашей учетной записи на данный момент не зафиксированы.</p>
                <a asp-page="/BookingFlow/New" class="btn btn--primary btn--sm">
                    <span>Выбрать время и записаться</span>
                </a>
            </div>
        }
    </section>
</section>
